---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import RoadmapApp from '../components/RoadmapApp';
import { ALL_EXAMS } from '../data/exams';

const ROADMAP_FAQS = [
  {
    question: 'How do I read my study roadmap?',
    answer: 'Your roadmap is organised by subject and day. Each day shows the topics to study, in the order that maximises your score potential. Start from Day 1 and work through sequentially — topics marked higher-weight are the ones most likely to appear on exam day.',
  },
  {
    question: 'What if I miss a day or fall behind?',
    answer: 'Simply pick up from where you stopped. The roadmap is a guide, not a strict schedule. If you miss several days, focus on the highest-weight remaining topics first — our algorithm always prioritises the most exam-relevant content.',
  },
  {
    question: 'Can I reset or regenerate my roadmap?',
    answer: 'Yes — just reload the page and select your exam and duration again. Your previous roadmap will be replaced. There is no account needed and no limit on how many roadmaps you generate.',
  },
  {
    question: 'How is the daily study plan generated?',
    answer: 'We analyse the official syllabus weightings for each topic of your chosen exam. The algorithm selects and sequences the highest-impact topics based on your available time, so you always study what matters most first.',
  },
  {
    question: 'Can I change my roadmap after generating it?',
    answer: 'You can generate a new roadmap at any time by selecting a different exam or duration. Each generation is independent — there is no save feature because no account is required.',
  },
  {
    question: 'Is my roadmap data saved anywhere?',
    answer: 'No. Everything happens in your browser. Your exam choices and roadmap are stored only in your browser local storage and are never transmitted to any server.',
  },

  {
    question: 'How does StudyRoadmap support Indian exam preparation?',
    answer: 'StudyRoadmap covers all major Indian entrance exams — NEET, JEE Main, JEE Advanced, CUET, UPSC, SSC CGL, CAT, CLAT, NDA, and UGC NET. Select your exam and available time to get an instant, prioritised study plan based on official syllabus weightings. All content is free, no login required.',
  },
  {
    question: "Which countries' exams are available on StudyRoadmap?",
    answer: 'StudyRoadmap covers exams across three countries: India (NEET, JEE, CUET, UPSC, SSC CGL, CAT, CLAT, NDA, UGC NET), Pakistan (MDCAT, ECAT, NAT-I, LAT, HAT-UG), and Nigeria (JAMB, WAEC, NECO, NABTEB, NCEE). All exams are completely free to plan for.',
  },
  {
    question: 'Can I use StudyRoadmap on a mobile phone?',
    answer: 'Yes. StudyRoadmap is designed for low-data and mobile environments. All pages are lightweight and load quickly even on 2G connections. No app download is needed — just open the website and generate your roadmap instantly.',
  },
  {
    question: 'Is there any exam for Pakistan on StudyRoadmap?',
    answer: 'Yes. StudyRoadmap covers MDCAT (medical), ECAT (engineering), NAT-I, LAT (law), and HAT-UG (universities) for Pakistan. Select your exam and duration to get an instant, algorithm-generated study plan.',
  },
  {
    question: 'What Nigerian exams are available?',
    answer: 'StudyRoadmap covers JAMB UTME, WAEC, NECO, NABTEB, and NCEE. Whether you are preparing for university admission or secondary school certification, select your exam and timeline to get a ranked study plan instantly.',
  },
  {
    question: 'How often is exam content updated?',
    answer: 'StudyRoadmap syllabus data is reviewed regularly. Each exam page lists the topics and their weightings based on the latest official exam patterns. If you notice outdated content, you can report it via the contact email on the site.',
  },
];

// Exam-specific FAQs — injected into the page when a user selects an exam
const EXAM_FAQS: Record<string, Array<{ question: string; answer: string }>> = {
  'neet': [
    { question: 'What is the eligibility criteria for NEET UG?', answer: 'Candidates must be at least 17 years old as of December 31 of the admission year. There is no upper age limit for NEET (as of the latest NMC rule). Academic requirement: 50% marks in Physics, Chemistry, and Biology (PCB) in the qualifying examination for the general category; 40% for reserved categories. Students appearing in Class 12 can also apply.' },
    { question: 'What is the exam pattern for NEET?', answer: 'NEET consists of 200 multiple-choice questions (180 mandatory + 10 optional), to be answered within 3 hours and 20 minutes. The paper covers three subjects: Physics (50 questions), Chemistry (50 questions), and Biology (100 questions — 90 mandatory + 10 optional). Each correct answer earns 4 marks; 1 mark is deducted for each wrong answer.' },
    { question: 'How many attempts are allowed for NEET?', answer: 'There is no limit on the number of attempts for NEET, provided the candidate meets the age and eligibility criteria. However, the upper age limit has been a subject of judicial review — check the latest NMC guidelines before applying.' },
  ],
  'jeemain': [
    { question: 'What is the eligibility for JEE Main?', answer: 'Candidates must have passed Class 12 or be appearing in the current academic year. There is no minimum aggregate requirement for appearing in JEE Main, but for admission to NITs, IIITs, and CFTIs, candidates typically need 75% or above (or be in the top 20 percentile of their board). For SC/ST candidates, the requirement is 65%.' },
    { question: 'What is the JEE Main exam pattern?', answer: 'JEE Main consists of 90 multiple-choice questions (30 per subject: Physics, Chemistry, Mathematics) with 25 questions each in Sections A (MCQs) and B (Numerical Value). Candidates attempt any 5 of the 10 questions in Section B. Each MCQ carries 4 marks; each numerical question carries 4 marks (no negative marking for numerical). Total time: 3 hours.' },
    { question: 'How many attempts per year for JEE Main?', answer: 'JEE Main is conducted twice a year (January and April sessions). A candidate can appear for both sessions in the same year. There is no cap on the total number of attempts across years, but only the best of the two scores is considered for the merit list.' },
  ],
  'jeeadvanced': [
    { question: 'Who is eligible to appear for JEE Advanced?', answer: 'Only the top 2,50,000 rankers in JEE Main (including all categories) are eligible to appear for JEE Advanced. Additionally, candidates must be among the top 20 percentile of their respective board examination. Age limit: candidates should have been born on or after October 1, 1998 (5-year relaxation for SC/ST/PwD candidates).' },
    { question: 'What is the JEE Advanced exam pattern?', answer: 'JEE Advanced consists of multiple papers (Paper 1 and Paper 2, each of 3 hours). The question paper comprises three subjects: Physics, Chemistry, and Mathematics. Questions are a mix of MCQs, numerical answer type (NAT), and comprehension/match columns. The marking scheme varies each year and is detailed in the Information Brochure released annually.' },
    { question: 'What is theSylabus overlap between JEE Main and JEE Advanced?', answer: 'The JEE Advanced syllabus is broadly similar to JEE Main but goes deeper and includes additional topics. Key additions in JEE Advanced include: General Organic Chemistry (detailed), Chemical Thermodynamics (extended), Electronic Devices (additional topics), and more complex problem-solving expectations across all three subjects.' },
  ],
  'upsc': [
    { question: 'What is the eligibility for UPSC Civil Services Examination?', answer: 'Candidates must hold a degree (graduation in any discipline) from a recognised university. Age limit: 21 to 32 years as of August 1 of the exam year for the general category. Attempts allowed: 6 for general category; 9 for OBC; unlimited for SC/ST (until the age limit is reached. PwD candidates get additional attempts based on their category.' },
    { question: 'What are the stages of the UPSC exam?', answer: 'The UPSC Civil Services Examination has three stages: (1) Preliminary Examination (Objective MCQs — General Studies Paper I and CSAT Paper II), (2) Mains Examination (Conventional/Descriptive — 9 papers including an Essay, four General Studies, two optional papers, and two language papers), and (3) Personality Test/Interview (275 marks). The final merit list is based on Mains + Interview.' },
    { question: 'What is the exam pattern for UPSC Prelims?', answer: 'UPSC Prelims consists of two objective-type papers: General Studies Paper I (200 marks, 80 questions on history, geography, polity, economy, science, environment, and current affairs) and CSAT Paper II (200 marks, 80 questions on comprehension, logical reasoning, and analytical ability). CSAT is qualifying in nature (33% threshold). Both papers are of 2 hours each. Negative marking applies: 0.66 marks deducted for each wrong answer.' },
  ],
  'cat': [
    { question: 'What is the eligibility to appear for CAT?', answer: 'Candidates must hold a Bachelor\'s degree with at least 50% marks (45% for SC/ST/PwD) from a recognised university. Final-year undergraduate students can also apply. There is no minimum work experience requirement. Candidates from any academic background — engineering, arts, commerce, science — are eligible.' },
    { question: 'What is the CAT exam pattern?', answer: 'CAT is a computer-based test of 2 hours (120 minutes). The exam has three sections: VARC (24 questions), DILR (20 questions), and QA (22 questions). Each correct answer carries 3 marks; 1 mark is deducted for each wrong answer in the MCQ section. There is no negative marking for TITA (Type in the Answer) questions. The test is adaptive in some years.' },
    { question: 'What is a good CAT score for IIM admission?', answer: 'A CAT score above 99 percentile (typically 97–99+ sectional percentiles) is considered competitive for top IIMs (IIM-A, B, C, L, K, S). The exact cutoff varies by IIM, category, and academic background. For newer IIMs and baby IIMs, the 90–95 percentile range is usually sufficient. Beyond the CAT score, WAT and PI rounds also carry significant weight in the final selection.' },
  ],
  'mdcat': [
    { question: 'What is the eligibility for MDCAT?', answer: 'Candidates must have completed F.Sc. (Pre-Medical) or an equivalent qualification with a minimum of 65% marks aggregate. They must also appear in the MDCAT entrance test conducted by PMDC. For international seats, the requirements may differ — check with the respective university. The test is mandatory for admission to all medical colleges in Pakistan.' },
    { question: 'What is the exam pattern for MDCAT?', answer: 'MDCAT is a multiple-choice question (MCQ) based test of 180 questions to be attempted in 3 hours and 30 minutes. The distribution is: Biology (60 MCQs), Chemistry (60 MCQs), Physics (30 MCQs), and English (30 MCQs, usually from University Admission Test pattern). The test is conducted annually, typically in August or September. Negative marking applies: 0.5 marks deducted per wrong answer.' },
    { question: 'What is the passing score for MDCAT?', answer: 'The PMDC sets a minimum passing threshold each year. The passing marks are typically 65% overall. For government medical colleges, the merit is calculated based on MDCAT score (50%), F.Sc./HSSC marks (40%), and interview (10%) or as per the latest PMDC policy. Private medical colleges set their own merit thresholds.' },
  ],
  'jamb': [
    { question: 'What is the eligibility for JAMB?', answer: 'Candidates must have a Senior Secondary School Certificate (SSCE) or its equivalent with at least five (5) credit passes, including English Language and Mathematics (for most courses). The UTME (Unified Tertiary Matriculation Examination) is open to students who have completed or are in their final year of secondary school education. There is no age limit.' },
    { question: 'What is the JAMB UTME exam pattern?', answer: 'JAMB UTME consists of 180 multiple-choice questions to be answered in 2 hours. The four subjects are: Use of English (compulsory for all candidates), and three other subjects relevant to the candidate\'s chosen university course. Each subject has 60 questions. There is no negative marking. The exam is computer-based (CBT).' },
    { question: 'What is the JAMB syllabus and how should I use it?', answer: 'The JAMB syllabus covers all subjects and specifies the topics and objectives for each. Candidates are advised to study the official JAMB syllabus (available on the JAMB website) and focus on the stated objectives under each topic. Past questions from previous years are also highly valuable for pattern recognition and time management practice.' },
  ],
  'clat': [
    { question: 'What is the eligibility for CLAT?', answer: 'For the undergraduate CLAT programme, candidates must have completed their Higher Secondary School Certificate (12th grade) or equivalent examination with at least 45% marks (40% for SC/ST/PwD candidates). There is no upper age limit for appearing in CLAT. Candidates appearing in the 12th grade in the current academic year are also eligible to apply.' },
    { question: 'What is the CLAT exam pattern?', answer: 'CLAT (Undergraduate) consists of 150 multiple-choice questions to be answered in 2 hours. The sections are: English Language, Current Affairs (including General Knowledge), Legal Reasoning, Logical Reasoning, and Quantitative Techniques (Mathematics). Each question carries 1 mark; 0.25 marks are deducted for each wrong answer.' },
    { question: 'What is a good CLAT score for top law schools?', answer: 'A score above 100–110 out of 150 is typically competitive for the top 5 NLUs (National Law Universities). For NLU Delhi and the top-tier NLUs, a score of 120+ is considered strong. Since the exam is standardised, the percentile matters more than the raw score. Candidates aiming for NLU-A should target a rank within the top 500.' },
  ],
  'gate': [
    { question: 'What is the GATE exam pattern?', answer: 'GATE consists of 65 questions worth 100 marks. The exam has two main sections: General Aptitude (15 marks, all candidates) and the subject-specific paper (85 marks). Questions are a mix of Multiple Choice Questions (MCQs) and Numerical Answer Type (NAT) questions. The exam is conducted online (CBT) in English only, for 3 hours.' },
    { question: 'What is the General Aptitude section in GATE?', answer: 'General Aptitude (GA) is a compulsory 15-mark section in every GATE paper — worth 15% of the total score. It covers Verbal Ability (4–5 questions on grammar, antonyms, analogies, reading comprehension) and Numerical Aptitude (8–9 questions on statistics, probability, algebra, geometry). Since every GATE aspirant faces GA, a strong foundation here reliably adds 10–13 marks at minimal effort compared to specialised subject study.' },
    { question: 'How is GATE score calculated?', answer: 'GATE uses a normalised score formula for multi-session papers. The raw score (out of 100) is converted to a GATE score out of 1000 using: GATE Score = 10 + (raw_score × 90/100). The qualifying cutoff varies by paper and category each year. For admission to M.Tech programmes in IITs/NITs, a GATE score of 650+ is generally competitive for top institutes; PSUs typically require 700–800+.' },
    { question: 'Which GATE paper should I attempt?', answer: 'Your GATE paper must align with your B.E./B.Tech discipline. Common papers: Computer Science (CS), Electronics & Communication (EC), Electrical (EE), Mechanical (ME), Civil (CE), Instrumentation (IN), and subject-specific papers like Chemistry (CY) or Physics (PH). The General Aptitude section is the same for all — StudyRoadmap covers all GA topics regardless of your engineering branch.' },
  ],
};

// Group exams by country for the "Browse More" internal links section
const byCountry = {
  india:    { label: 'India',    flag: '🇮🇳', exams: ALL_EXAMS.filter(e => e.country === 'india') },
  pakistan: { label: 'Pakistan', flag: '🇵🇰', exams: ALL_EXAMS.filter(e => e.country === 'pakistan') },
  nigeria:  { label: 'Nigeria',  flag: '🇳🇬', exams: ALL_EXAMS.filter(e => e.country === 'nigeria') },
};

---

<Layout
  title="Generate Your Study Roadmap — StudyRoadmap™"
  description="Choose your exam and timeline — get an instant personalised study plan. Free, no signup, for NEET, JEE, UPSC, MDCAT, JAMB and more."
  faqs={ROADMAP_FAQS}
>
  <Navbar />

  <main id="main-content" class="flex-1">
    <!-- Page header -->
    <section class="bg-surface-50 dark:bg-surface-950 border-b border-surface-200 dark:border-surface-800">
      <div class="container-page py-14 sm:py-20 text-center">
        <h1 class="heading-1 text-surface-900 dark:text-surface-50 mb-3">
          Study Roadmap Generator
        </h1>
        <p class="text-base sm:text-lg text-surface-600 dark:text-surface-400 max-w-xl mx-auto">
          Choose your exam and timeline — get an instant personalised study plan.
        </p>
      </div>
    </section>

    <!-- React island: all interactivity lives here -->
    <RoadmapApp exams={ALL_EXAMS} client:load />

    <!-- Exam-specific FAQ section (populated by JS when exam is selected) -->
    <section id="exam-faq-section" class="hidden border-t border-surface-200 dark:border-surface-800">
      <div class="container-page py-12">
        <h2 class="heading-2 text-surface-900 dark:text-surface-50 mb-2" id="exam-faq-heading">📋 Exam FAQs</h2>
        <p class="text-sm text-surface-500 dark:text-surface-400 mb-8">
          Common questions about this exam's eligibility, pattern, and preparation strategy.
        </p>
        <div id="exam-faq-list" class="space-y-4"></div>
      </div>
    </section>

    <!-- Study Notes section -->
    <section class="bg-surface-50 dark:bg-surface-950 border-t border-surface-200 dark:border-surface-800">
      <div class="container-page py-12">
        <div class="flex items-center justify-between mb-3">
          <h2 class="heading-2 text-surface-900 dark:text-white">📚 Free Study Notes</h2>
          <a href="/notes" class="text-sm font-medium text-brand-600 dark:text-brand-400 hover:underline">
            All exams →
          </a>
        </div>
        <p class="text-sm text-surface-500 dark:text-surface-400 mb-8">
          Browse 1,263 topic notes across all exams — each note includes a diagram prompt and exam-weight guidance.
        </p>
        <div class="grid sm:grid-cols-3 gap-8">
          {Object.entries(byCountry).map(([code, { label, flag, exams }]) => (
            <div>
              <div class="flex items-center gap-2 mb-4">
                <span class="text-xl">{flag}</span>
                <h3 class="font-semibold text-surface-800 dark:text-surface-100">{label}</h3>
                <span class="text-xs text-surface-400 bg-surface-100 dark:bg-surface-800 px-2 py-0.5 rounded-full">
                  {exams.length} exams
                </span>
              </div>
              <ul class="space-y-2">
                {exams.map(exam => (
                  <li class="flex items-center justify-between gap-2">
                    <a
                      href={`/roadmap?exam=${exam.examId}`}
                      class="text-sm text-surface-600 dark:text-surface-300 hover:text-brand-600 dark:hover:text-brand-400 hover:underline flex items-center gap-1.5"
                    >
                      <span class="text-surface-400">→</span>
                      {exam.examName}
                    </a>
                    <a
                      href={`/notes/${exam.examId}`}
                      class="text-xs text-brand-600 dark:text-brand-400 hover:underline shrink-0"
                      aria-label={`${exam.examName} study notes`}
                    >
                      notes →
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Exam pages quick links -->
    <section class="border-t border-surface-200 dark:border-surface-800">
      <div class="container-page py-10">
        <h2 class="heading-3 text-surface-800 dark:text-surface-100 mb-6">Browse All Exams</h2>
        <div class="flex flex-wrap gap-2">
          {ALL_EXAMS.map(exam => (
            <a
              href={`/roadmap?exam=${exam.examId}`}
              class="text-sm px-3 py-1.5 bg-surface-100 dark:bg-surface-800 text-surface-700 dark:text-surface-300 rounded-full hover:bg-brand-50 dark:hover:bg-brand-950 hover:text-brand-700 dark:hover:text-brand-300 border border-surface-200 dark:border-surface-700 transition-colors"
            >
              {exam.examName}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Dynamic exam-specific FAQ injection -->
  <script is:inline define:vars={{ EXAM_FAQS }}>
    (function () {
      const examFaqSection = document.getElementById('exam-faq-section');
      const examFaqList = document.getElementById('exam-faq-list');
      const examFaqHeading = document.getElementById('exam-faq-heading');
      let currentExam = null;

      function getExamFromUrl() {
        const params = new URLSearchParams(window.location.search);
        return params.get('exam') || null;
      }

      function slugify(str) {
        return str.toLowerCase().replace(/-/g, '');
      }

      function findExamKey(urlKey) {
        if (!urlKey) return null;
        const normalized = slugify(urlKey);
        for (const key of Object.keys(EXAM_FAQS)) {
          if (slugify(key) === normalized || key === urlKey) return key;
        }
        return null;
      }

      function renderFaqs(examKey) {
        if (!examKey || !EXAM_FAQS[examKey]) {
          examFaqSection.classList.add('hidden');
          currentExam = null;
          return;
        }

        const faqs = EXAM_FAQS[examKey];
        const examName = examKey.toUpperCase();
        examFaqHeading.textContent = '📋 ' + examName + ' FAQs';
        examFaqList.innerHTML = '';

        faqs.forEach(function (faq) {
          var item = document.createElement('details');
          item.className = 'group bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-700 rounded-lg overflow-hidden';

          var summary = document.createElement('summary');
          summary.className = 'flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none font-medium text-surface-800 dark:text-surface-100 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors';
          summary.innerHTML = '<span>' + faq.question + '</span><span class="text-surface-400 group-open:rotate-45 transition-transform">+</span>';

          var answer = document.createElement('div');
          answer.className = 'px-5 pb-4 text-sm text-surface-600 dark:text-surface-300 leading-relaxed border-t border-surface-100 dark:border-surface-800 pt-3';
          answer.textContent = faq.answer;

          item.appendChild(summary);
          item.appendChild(answer);
          examFaqList.appendChild(item);
        });

        examFaqSection.classList.remove('hidden');
        currentExam = examKey;
      }

      function updateJsonLd(examKey) {
        // Remove existing exam-specific FAQPage JSON-LD
        var existing = document.getElementById('exam-specific-faq-jsonld');
        if (existing) existing.remove();

        if (!examKey || !EXAM_FAQS[examKey]) return;

        var script = document.createElement('script');
        script.id = 'exam-specific-faq-jsonld';
        script.type = 'application/ld+json';
        script.textContent = JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: EXAM_FAQS[examKey].map(function (f) {
            return {
              '@type': 'Question',
              name: f.question,
              acceptedAnswer: { '@type': 'Answer', text: f.answer },
            };
          }),
        });
        document.head.appendChild(script);
      }

      function onExamChange() {
        var examKey = findExamKey(getExamFromUrl());
        if (examKey !== currentExam) {
          renderFaqs(examKey);
          updateJsonLd(examKey);
        }
      }

      // Initial load
      onExamChange();

      // React router may update URL without page reload
      var lastUrl = window.location.href;
      var pollInterval = setInterval(function () {
        if (window.location.href !== lastUrl) {
          lastUrl = window.location.href;
          onExamChange();
        }
      }, 500);

      // Also handle browser back/forward
      window.addEventListener('popstate', function () {
        lastUrl = window.location.href;
        onExamChange();
      });
    })();
  </script>
</Layout>
