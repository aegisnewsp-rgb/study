---
import '../styles/global.css';
import { ALL_EXAMS } from '../data/exams';
const examCountLabel = `${ALL_EXAMS.length}+`;

interface FAQItem {
  question: string;
  answer: string;
}

interface HowToStep {
  name: string;
  text: string;
}

interface AuthorPerson {
  name: string;
  jobTitle: string;
  affiliation?: string;
  url?: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  faqs?: FAQItem[];
  howToSteps?: HowToStep[];
  robots?: string;
  author?: AuthorPerson;
}

const {
  title = 'StudyRoadmap™ — AI Study Plans for 80+ Exams',
  description = 'Instant personalized study roadmaps for NEET, JEE, UPSC, MDCAT, JAMB and 80+ competitive exams. Free, no signup required.',
  image = '/og-image.svg',
  faqs = [],
  howToSteps = [],
  robots,
  author,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <!-- Privacy-friendly analytics by Plausible -->
    <script async src="http://187.127.134.151:55412/js/pa-3Wzng1fo7sbq7otODC79C.js"></script>
    <script>
      window.plausible = window.plausible || function() { (plausible.q = plausible.q || []).push(arguments); };
      plausible.init = plausible.init || function() {};
      plausible.init();
    </script>

    <meta charset="UTF-8" />
    <!-- Performance: preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Async load Inter font — avoids render-blocking CSS @import -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" /></noscript>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    {robots && <meta name="robots" content={robots} />}

    <!-- Google Search Console Verification -->
    <!-- Replace the content value below with your actual Search Console verification meta tag -->
    <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE_HERE" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta name="theme-color" content="#1d4ed8" />
    <meta name="msvalidate.01" content="BING_VERIFICATION_CODE" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:site" content="@studyroadmap_in" />
    <meta name="twitter:creator" content="@studyroadmap_in" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Organization Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://studyroadmap.in/#organization",
      "name": "StudyRoadmap",
      "url": "https://studyroadmap.in",
      "description": "Free AI-powered study roadmap generator for 80+ competitive exams across India, Pakistan, and Nigeria. No signup required.",
      "logo": {
        "@type": "ImageObject",
        "url": "https://studyroadmap.in/og-image.svg"
      },
      "sameAs": [
        "https://github.com/aegisnewsp-rgb"
      ]
    })} />

    <!-- WebSite Schema with SearchAction — enables Google Sitelinks search box -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "StudyRoadmap",
      "url": "https://studyroadmap.in",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://studyroadmap.in/roadmap?exam={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- FAQPage Structured Data -->
    {faqs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.answer,
          },
        })),
      })} />
    )}

    <!-- Person Schema — author / editor signal for E-E-E-A-T -->
    {author && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": author.name,
        "jobTitle": author.jobTitle,
        "affiliation": author.affiliation ? { "@type": "Organization", "name": author.affiliation } : undefined,
        "url": author.url,
      })} />
    )}

    <!-- HowTo Structured Data — step-by-step guide for using the roadmap tool -->
    {howToSteps.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "How to generate your free study roadmap",
        "description": "Follow these steps to get your instant personalised study plan for any competitive exam on StudyRoadmap",
        "step": howToSteps.map((s, i) => ({
          "@type": "HowToStep",
          "position": i + 1,
          "name": s.name,
          "text": s.text,
        })),
      })} />
    )}

    <!-- Dark mode: prevent FOUC -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Skip navigation — WCAG 2.1 AA: lets keyboard users jump past nav to main content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-brand-600 focus:text-white focus:font-semibold focus:rounded-lg focus:shadow-lg"
    >
      Skip to main content
    </a>

    <slot />
  </body>
</html>
