---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const LAST_UPDATED = 'March 2026';

const EXAM_STATS = [
  { value: '21', label: 'Exams', sub: 'India, Pakistan & Nigeria' },
  { value: '3',  label: 'Countries', sub: 'South Asia & West Africa' },
  { value: '200+', label: 'Topics', sub: 'Syllabus-mapped & weighted' },
  { value: '100%', label: 'Free', sub: 'No signup, no fees' },
];
---

<Layout
  title="About StudyRoadmap™ — Free AI Study Plans"
  description="Learn about StudyRoadmap™ — a free planning tool for students across India, Pakistan, and Nigeria preparing for competitive exams."
>
  <Navbar />

  <main id="main-content" class="flex-1">
    <section class="bg-surface-50 dark:bg-surface-950 border-b border-surface-200 dark:border-surface-800">
      <div class="container-page py-14 sm:py-20 text-center">
        <h1 class="heading-1 text-surface-900 dark:text-surface-50 mb-3">About StudyRoadmap™</h1>
        <p class="text-base sm:text-lg text-surface-600 dark:text-surface-400 max-w-xl mx-auto">
          Built for students, by students who understand the struggle of exam prep.
        </p>
      </div>
    </section>

    <!-- Stats banner -->
    <section class="bg-brand-600 py-8">
      <div class="container-page">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
          {EXAM_STATS.map(s => (
            <div class="text-center">
              <div class="text-3xl font-black text-white">{s.value}</div>
              <div class="text-sm font-semibold text-brand-100">{s.label}</div>
              <div class="text-xs text-brand-200 mt-0.5">{s.sub}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="container-page py-14 max-w-3xl mx-auto space-y-12">
      <div class="card p-6 sm:p-8">
        <h2 class="heading-2 text-surface-900 dark:text-white mb-4">What is StudyRoadmap™?</h2>
        <div class="space-y-4 text-surface-600 dark:text-surface-400 leading-relaxed">
          <p>
            StudyRoadmap™ is a <strong class="text-surface-900 dark:text-surface-100">free, instant study planning tool</strong> that generates personalised roadmaps for students preparing for competitive exams across India, Pakistan, and Nigeria.
          </p>
          <p>
            Whether you're preparing for <strong class="text-surface-900 dark:text-surface-100">NEET, JEE, UPSC, MDCAT, JAMB, WAEC</strong> or any of the 20+ exams we support — just select your exam, choose your timeline, and get a structured study plan in seconds. No signup, no fees.
          </p>
        </div>
      </div>

      <div class="card p-6 sm:p-8">
        <h2 class="heading-2 text-surface-900 dark:text-white mb-4">How It Works</h2>
        <div class="space-y-4 text-surface-600 dark:text-surface-400 leading-relaxed">
          <p>
            We analyse the official syllabus and weightings for each exam topic. Based on your available preparation time, our algorithm selects and sequences the most impactful topics — so you always know exactly what to study next.
          </p>
          <p>
            The roadmap is broken down by <strong class="text-surface-900 dark:text-surface-100">subject</strong> and <strong class="text-surface-900 dark:text-surface-100">topic priority</strong>, with high-weight topics surfaced first. You can switch durations instantly to see how your plan adapts.
          </p>
        </div>
      </div>

      <div class="card p-6 sm:p-8">
        <h2 class="heading-2 text-surface-900 dark:text-white mb-4">Built for Students, by Students</h2>
        <div class="space-y-4 text-surface-600 dark:text-surface-400 leading-relaxed">
          <p>
            StudyRoadmap™ was created to solve a problem every competitive exam student knows: where do I start? With so many topics, so little time, and coaching only accessible to those who can afford it — the gap between those with a plan and those without is enormous.
          </p>
          <p>
            We believe a good study plan should be free. Every student, regardless of background or location, deserves to know which topics matter most and in what order to study them. That's the gap StudyRoadmap™ exists to fill.
          </p>
        </div>
      </div>

      <div class="card p-6 sm:p-8">
        <h2 class="heading-2 text-surface-900 dark:text-white mb-4">Our Mission</h2>
        <div class="space-y-4 text-surface-600 dark:text-surface-400 leading-relaxed">
          <p>
            Every student deserves access to quality study planning — regardless of whether they can afford expensive coaching. StudyRoadmap™ levels the playing field by giving every student a structured, data-driven study plan <strong class="text-surface-900 dark:text-surface-100">completely free</strong>.
          </p>
          <p>
            We're starting with South Asia and Africa, where competitive exam pressure is highest and access to structured planning tools is often limited to those who can pay for coaching.
          </p>
        </div>
      </div>

      <div class="card p-6 sm:p-8">
        <h2 class="heading-2 text-surface-900 dark:text-white mb-4">Important Disclaimer</h2>
        <div class="p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl text-sm text-amber-800 dark:text-amber-200 leading-relaxed">
          StudyRoadmap™ is a <strong>planning aid only</strong>. The roadmaps are generated based on publicly available syllabus information and are not affiliated with any exam board or conducting body. Always verify information with official sources before making decisions about your exam preparation.
        </div>
      </div>

      <div class="card p-6 sm:p-8">
        <h2 class="heading-2 text-surface-900 dark:text-white mb-4">How We Keep Roadmaps Accurate</h2>
        <div class="space-y-4 text-surface-600 dark:text-surface-400 leading-relaxed">
          <p>
            Every roadmap is tied to the official exam syllabus published by the conducting body. When an exam board releases updated syllabuses or announces pattern changes, we review and revise the affected roadmap data.
          </p>
          <p>
            Our process: we monitor official exam board websites (NTA, JAMB, PMDC, WAEC, and others listed below) for syllabus and notification updates. Roadmaps are built from topic-level syllabus weightings, not guesswork — the priority order of topics within each subject reflects how often and how heavily that topic has appeared in recent exam papers.
          </p>
          <p class="text-sm text-surface-500 dark:text-surface-500">
            <strong>Note:</strong> Exam schedules, eligibility criteria, and registration dates change frequently. Always confirm the latest information directly from your exam board's official website before making decisions.
          </p>
        </div>
      </div>

      <div class="card p-6 sm:p-8">
        <h2 class="heading-2 text-surface-900 dark:text-white mb-4">Methodology & Sources</h2>
        <div class="space-y-4 text-surface-600 dark:text-surface-400 leading-relaxed">
          <p>
            Every roadmap is built from publicly available syllabus and exam pattern data published by the official conducting bodies. We analyse topic weightings from past exam papers and official curriculum documents, then sequence topics by impact and feasibility within your chosen time window.
          </p>
          <p>
            We do not have official partnerships with any exam board. All information is sourced from public documents and is intended as a supplementary planning tool only.
          </p>
          <div class="grid sm:grid-cols-3 gap-3 mt-4">
            <a href="https://neet.nta.nic.in/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 p-3 rounded-lg border border-surface-200 dark:border-surface-700 hover:border-brand-400 dark:hover:border-brand-600 transition-colors group">
              <span class="text-lg">🇮🇳</span>
              <div>
                <div class="text-xs font-semibold text-surface-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400">India</div>
                <div class="text-xs text-surface-500">NTA (NEET, JEE, CUET)</div>
              </div>
            </a>
            <a href="https://www.upsc.gov.in/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 p-3 rounded-lg border border-surface-200 dark:border-surface-700 hover:border-brand-400 dark:hover:border-brand-600 transition-colors group">
              <span class="text-lg">🇮🇳</span>
              <div>
                <div class="text-xs font-semibold text-surface-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400">India</div>
                <div class="text-xs text-surface-500">UPSC (Civil Services)</div>
              </div>
            </a>
            <a href="https://www.jamb.gov.ng/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 p-3 rounded-lg border border-surface-200 dark:border-surface-700 hover:border-brand-400 dark:hover:border-brand-600 transition-colors group">
              <span class="text-lg">🇳🇬</span>
              <div>
                <div class="text-xs font-semibold text-surface-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400">Nigeria</div>
                <div class="text-xs text-surface-500">JAMB (UTME)</div>
              </div>
            </a>
            <a href="https://www.pmdc.edu.pk/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 p-3 rounded-lg border border-surface-200 dark:border-surface-700 hover:border-brand-400 dark:hover:border-brand-600 transition-colors group">
              <span class="text-lg">🇵🇰</span>
              <div>
                <div class="text-xs font-semibold text-surface-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400">Pakistan</div>
                <div class="text-xs text-surface-500">PMDC (MDCAT)</div>
              </div>
            </a>
            <a href="https://www.waec.org.ng/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 p-3 rounded-lg border border-surface-200 dark:border-surface-700 hover:border-brand-400 dark:hover:border-brand-600 transition-colors group">
              <span class="text-lg">🇳🇬</span>
              <div>
                <div class="text-xs font-semibold text-surface-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400">Nigeria</div>
                <div class="text-xs text-surface-500">WAEC (WASSCE)</div>
              </div>
            </a>
            <a href="https://www.ssc.gov.pk/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 p-3 rounded-lg border border-surface-200 dark:border-surface-700 hover:border-brand-400 dark:hover:border-brand-600 transition-colors group">
              <span class="text-lg">🇵🇰</span>
              <div>
                <div class="text-xs font-semibold text-surface-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400">Pakistan</div>
                <div class="text-xs text-surface-500">ECAT, NTS</div>
              </div>
            </a>
          </div>
        </div>
      </div>

      <p class="text-center text-xs text-surface-400">
        Last updated: {LAST_UPDATED} · StudyRoadmap™ is not affiliated with any exam board.
      </p>
    </section>
  </main>

  <Footer />
</Layout>
