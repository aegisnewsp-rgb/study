---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const NEET_FAQS = [
  {
    question: 'How to make a NEET preparation strategy for 2026–2027?',
    answer: 'A winning NEET strategy starts with knowing which topics carry the most weight in the exam: Physics (25%), Chemistry (25%), Biology (50%). Use StudyRoadmap\'s free AI generator to create a personalised roadmap based on your available time — the algorithm prioritises high-weight topics like Human Physiology, Genetics, Organic Chemistry, and Electrodynamics first, so you always study what matters most.',
  },
  {
    question: 'How many hours should I study for NEET per day?',
    answer: 'Most top NEET scorers study 6–8 focused hours daily. However, the right number depends on your preparation level and remaining time. StudyRoadmap\'s AI adapts to your exact time window — whether you have 2 hours or 12 hours per day. Focus and consistency beat long hours with distraction.',
  },
  {
    question: 'Is 6 months enough to prepare for NEET?',
    answer: 'Yes — 6 months is sufficient for NEET if you use a prioritised strategy. Focus on high-weight topics: Biology (Human Physiology, Genetics, Ecology), Chemistry (Organic reactions, Equilibrium, Electrochemistry), Physics (Mechanics, Electrodynamics, Modern Physics). Use a daily study plan and stick to it. Avoid spreading time thin across low-weight topics.',
  },
  {
    question: 'Which physics chapter has highest weightage in NEET?',
    answer: 'Based on NEET 2024 and 2025 papers: Human Physiology carries ~9% of Biology, followed by Genetics (~8%) and Ecology (~7%). In Physics, Electrodynamics (Electrostatics + Current Electricity + Magnetism) combined carries ~20%, Mechanics ~18%, and Optics ~8%. These are the highest-scoring areas to master first.',
  },
  {
    question: 'Can I crack NEET without coaching?',
    answer: 'Yes — thousands of students crack NEET every year without coaching, using self-study and the right resources. The key is a structured study plan that covers the entire NCERT syllabus thoroughly, combined with regular MCQ practice. StudyRoadmap\'s free AI roadmap tells you exactly what to study each day based on your available time.',
  },
  {
    question: 'What is the best study order for NEET Physics?',
    answer: 'For NEET Physics, follow this proven order: (1) Mechanics — foundational for all other topics; (2) Heat & Thermodynamics — moderate difficulty, high weightage; (3) Wave optics — easier to master; (4) Electrostatics & Capacitance — high weightage, conceptual; (5) Current Electricity — combines well with Electrostatics; (6) Magnetism & EMI — scoring topics; (7) Modern Physics — easiest to score, high weightage. StudyRoadmap generates this sequencing automatically.',
  },
  {
    question: 'How to score 600+ in NEET?',
    answer: 'To score 600+ in NEET (out of 720), you need approximately 160 correct answers. Target: Biology 160+ (min 35 correct in each Zoology and Botany), Chemistry 130+, Physics 120+. Focus on NCERT Biology (most questions are from NCERT lines), practice previous years\' papers, and take regular mock tests. Use a daily roadmap to cover weak areas systematically.',
  },
  {
    question: 'What are the most scoring topics in NEET Chemistry?',
    answer: 'In NEET Chemistry: (1) Organic Chemistry — Named reactions, Biomolecules, Hydrocarbons (~35% of chem questions); (2) Physical Chemistry — Electrochemistry, Chemical Kinetics, Equilibrium (~30%); (3) Inorganic Chemistry — p-Block, Coordination Compounds (~35%). Master named reactions and NCERT lines for maximum score.',
  },
];

const FAQ_SCHEMA = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": NEET_FAQS.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
  }))
};

const HOWTO_SCHEMA = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to create a NEET preparation strategy for 2026",
  "description": "Build a winning NEET study plan in 3 steps using the free AI study roadmap generator",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Analyse NEET syllabus and topic weightage", "text": "Understand which topics carry the most marks in NEET. Biology has 50% weightage (Human Physiology, Genetics, Ecology are highest). Physics and Chemistry each have 25%." },
    { "@type": "HowToStep", "position": 2, "name": "Set your preparation timeline", "text": "Enter your available hours per day and months until NEET into StudyRoadmap's free AI generator. Get an instant personalised roadmap with high-weight topics first." },
    { "@type": "HowToStep", "position": 3, "name": "Follow the roadmap and revise", "text": "Study according to your AI-generated daily plan. Cover NCERT thoroughly for Biology. Practice MCQs daily. Revise high-weight topics at least 3 times before the exam." }
  ]
};
---

<Layout
  title="NEET Preparation Strategy 2026–2027 | Free AI Study Roadmap"
  description="Proven NEET preparation strategy for 2026–2027. Create your free personalised AI study plan in 60 seconds. NEET syllabus analysis, topic weightage, study order, and daily roadmap generator."
  ogTitle="NEET Preparation Strategy 2026–2027 | Free AI Study Roadmap"
  ogDescription="Build your NEET preparation strategy with our free AI study roadmap generator. Personalised study plan based on NEET topic weightage."
  schema={[FAQ_SCHEMA, HOWTO_SCHEMA]}
>
  <Navbar />

  <main class="min-h-screen bg-surface-50 dark:bg-surface-900">
    <!-- Hero -->
    <section class="relative bg-gradient-to-br from-green-600 via-emerald-700 to-teal-800 text-white py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-block px-4 py-1.5 bg-white/20 rounded-full text-sm font-medium mb-6">
          NEET UG 2026–2027 Strategy Guide
        </span>
        <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
          NEET Preparation Strategy
        </h1>
        <p class="text-xl text-green-100 max-w-2xl mx-auto mb-4">
          How to prepare for NEET 2026–2027: topic weightage, study order, time management, and the free AI tool that builds your complete daily roadmap.
        </p>
        <p class="text-lg text-green-200 max-w-xl mx-auto mb-10">
          Trusted by students across India. 100% free. No signup required.
        </p>
        <a
          href="/roadmap?exam=neet"
          class="inline-flex items-center gap-2 bg-white text-green-700 font-bold text-lg px-8 py-4 rounded-xl hover:bg-green-50 transition-all shadow-lg hover:-translate-y-0.5"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Generate My NEET Study Roadmap — Free
        </a>
      </div>
    </section>

    <!-- Topic Weightage -->
    <section class="py-16 px-4 bg-white dark:bg-surface-800">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-4 text-surface-900 dark:text-white">
          NEET 2026–2027: Topic Weightage Breakdown
        </h2>
        <p class="text-center text-surface-600 dark:text-surface-400 mb-12 max-w-xl mx-auto">
          Biology carries 50% of NEET marks. Physics and Chemistry each carry 25%. Focus your time accordingly.
        </p>

        <div class="grid md:grid-cols-3 gap-8 mb-12">
          <!-- Biology -->
          <div class="bg-green-50 dark:bg-green-900/20 rounded-2xl p-6 border border-green-200 dark:border-green-800">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-green-800 dark:text-green-300">🧬 Biology</h3>
              <span class="text-3xl font-bold text-green-600 dark:text-green-400">50%</span>
            </div>
            <ul class="space-y-2 text-sm text-green-700 dark:text-green-300">
              <li>Human Physiology — <strong>~9%</strong></li>
              <li>Genetics & Evolution — <strong>~8%</strong></li>
              <li>Ecology & Environment — <strong>~7%</strong></li>
              <li>Cell Biology — <strong>~5%</strong></li>
              <li>Plant Kingdom — <strong>~4%</strong></li>
              <li>Animal Kingdom — <strong>~4%</strong></li>
              <li>Biotechnology — <strong>~4%</strong></li>
              <li>Human Reproduction — <strong>~4%</strong></li>
            </ul>
          </div>

          <!-- Chemistry -->
          <div class="bg-blue-50 dark:bg-blue-900/20 rounded-2xl p-6 border border-blue-200 dark:border-blue-800">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-blue-800 dark:text-blue-300">⚗️ Chemistry</h3>
              <span class="text-3xl font-bold text-blue-600 dark:text-blue-400">25%</span>
            </div>
            <ul class="space-y-2 text-sm text-blue-700 dark:text-blue-300">
              <li>Organic Chemistry — <strong>~8%</strong></li>
              <li>Physical Chemistry — <strong>~8%</strong></li>
              <li>Inorganic Chemistry — <strong>~9%</strong></li>
              <li>Equilibrium — <strong>~3%</strong></li>
              <li>Electrochemistry — <strong>~3%</strong></li>
              <li>p-Block Elements — <strong>~3%</strong></li>
            </ul>
          </div>

          <!-- Physics -->
          <div class="bg-orange-50 dark:bg-orange-900/20 rounded-2xl p-6 border border-orange-200 dark:border-orange-800">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-orange-800 dark:text-orange-300">⚡ Physics</h3>
              <span class="text-3xl font-bold text-orange-600 dark:text-orange-400">25%</span>
            </div>
            <ul class="space-y-2 text-sm text-orange-700 dark:text-orange-300">
              <li>Electrodynamics — <strong>~9%</strong></li>
              <li>Mechanics — <strong>~7%</strong></li>
              <li>Modern Physics — <strong>~5%</strong></li>
              <li>Optics — <strong>~4%</strong></li>
              <li>Heat & Thermodynamics — <strong>~3%</strong></li>
              <li>SHM & Waves — <strong>~3%</strong></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- NEET FAQ -->
    <section class="py-16 px-4 bg-surface-50 dark:bg-surface-900">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-4 text-surface-900 dark:text-white">
          NEET Preparation FAQs
        </h2>
        <p class="text-center text-surface-600 dark:text-surface-400 mb-12">
          Expert answers to the most common NEET preparation questions
        </p>

        <div class="space-y-4">
          {NEET_FAQS.map((faq) => (
            <details class="group bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700">
              <summary class="flex items-center justify-between cursor-pointer p-5 font-medium text-surface-900 dark:text-white list-none">
                <span>{faq.question}</span>
                <svg class="w-5 h-5 text-surface-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-surface-600 dark:text-surface-400 text-sm leading-relaxed">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 px-4 bg-gradient-to-r from-green-600 to-emerald-700 text-white text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold mb-4">Build Your Personalised NEET Roadmap</h2>
        <p class="text-green-100 mb-8 text-lg">
          Tell us your available hours and exam date. Get an AI-curated study plan in under 60 seconds.
        </p>
        <a
          href="/roadmap?exam=neet"
          class="inline-flex items-center gap-2 bg-white text-green-700 font-bold text-lg px-8 py-4 rounded-xl hover:bg-green-50 transition-all shadow-lg"
        >
          Generate My Free NEET Roadmap →
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
