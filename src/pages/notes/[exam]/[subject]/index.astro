---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  const subjects = [...new Set(allNotes.map(n => n.id.split('/').slice(0, 2).join('/')))];
  return subjects.map(slug => ({
    params: { exam: slug.split('/')[0], subject: slug.split('/')[1] },
    props: { slug },
  }));
}

const { slug } = Astro.props;
const allNotes = await getCollection('notes');
const subjectNotes = allNotes
  .filter(n => n.id.startsWith(slug + '/'))
  .sort((a, b) => a.data.topic.localeCompare(b.data.topic));

const { exam, subject } = Astro.params;
const firstNote = subjectNotes[0];
const examName = firstNote?.data.examName || exam;
const subjectName = firstNote?.data.subjectName || subject;
const flag = { india: '🇮🇳', pakistan: '🇵🇰', nigeria: '🇳🇬' }[firstNote?.data.country] || '🌍';

const title = `${subjectName} Study Notes — ${examName} | StudyRoadmap™`;
const description = `Free ${subjectName} study notes for ${examName}. ${subjectNotes.length} topics covered with Quick, Standard, and Deep content tiers — concept explanations, key formulas, NEET-level practice questions, and diagrams.`;
const canonicalUrl = `https://studyroadmap.in/notes/${exam}/${subject}`;
const siteUrl = 'https://studyroadmap.in';
const authorObj = { name: "StudyRoadmap Editorial Team", jobTitle: "Curriculum Editors", affiliation: "StudyRoadmap", url: "https://studyroadmap.in/about" };
const ogImage = `/og-notes/subject-${exam}-${subject}.jpg`;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Roadmap', item: `${siteUrl}/roadmap` },
    { '@type': 'ListItem', position: 3, name: examName, item: `${siteUrl}/roadmap?exam=${exam}` },
    { '@type': 'ListItem', position: 4, name: subjectName, item: canonicalUrl },
  ],
};

const faqs = [
  {
    question: `What topics are covered in ${subjectName} for ${examName}?`,
    answer: `${subjectName} for ${examName} covers ${subjectNotes.length} topics including ${subjectNotes.slice(0, 3).map(n => n.data.topicName).join(', ')}, and more. Each topic offers three content tiers: Quick (last-minute revision), Standard (comprehensive study), and Deep (expert-level coverage).`,
  },
  {
    question: `What is the weightage of ${subjectName} in ${examName}?`,
    answer: `${subjectName} carries significant weight in ${examName}. Our roadmap prioritises topics by their exam frequency and marks weightage, so you can focus on high-yield topics first and maximise your score with the time available.`,
  },
  {
    question: `Which ${subjectName} topics should I study first for ${examName}?`,
    answer: `Start with the highest-weighted topics in ${subjectName} for ${examName}. Our roadmap algorithm orders all topics by exam weight — covering the most frequently-tested concepts first so you score maximum marks early in your preparation.`,
  },
  {
    question: `Are these ${subjectName} notes enough for ${examName} preparation?`,
    answer: `These notes cover the complete ${examName} ${subjectName} syllabus with Quick, Standard, and Deep content tiers. Use them alongside your AI-generated study roadmap for prioritised study sessions and regular revision before exam day.`,
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const collectionPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${subjectName} Study Notes — ${examName}`,
  description: description,
  url: canonicalUrl,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: subjectNotes.map((note, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${siteUrl}/notes/${exam}/${subject}/${note.data.topic}`,
      name: note.data.topicName,
    })),
  },
};

// All subjects for this exam (for cross-linking)
const allSubjects = [...new Set(allNotes.map(n => n.id.split('/')[1]))];
const otherSubjects = allSubjects.filter(s => s !== subject).map(s => {
  const exampleNote = allNotes.find(n => n.id.split('/')[1] === s);
  return { id: s, name: exampleNote?.data.subjectName || s };
});

// Equivalent exams
const EXAM_EQUIVALENTS: Record<string, Array<{id: string; name: string; flag: string}>> = {
  'neet':       [{id:'mdcat', name:'MDCAT (Pakistan)', flag:'🇵🇰'}, {id:'jamb', name:'JAMB (Nigeria)', flag:'🇳🇬'}],
  'mdcat':      [{id:'neet', name:'NEET UG (India)', flag:'🇮🇳'}, {id:'jamb', name:'JAMB (Nigeria)', flag:'🇳🇬'}],
  'jamb':       [{id:'neet', name:'NEET UG (India)', flag:'🇮🇳'}, {id:'mdcat', name:'MDCAT (Pakistan)', flag:'🇵🇰'}],
  'jee-main':   [{id:'jeeadvanced', name:'JEE Advanced (India)', flag:'🇮🇳'}, {id:'ecat', name:'ECAT (Pakistan)', flag:'🇵🇰'}],
  'jeeadvanced':[{id:'jeemain', name:'JEE Main (India)', flag:'🇮🇳'}, {id:'ecat', name:'ECAT (Pakistan)', flag:'🇵🇰'}],
  'ecat':       [{id:'jeemain', name:'JEE Main (India)', flag:'🇮🇳'}, {id:'jeeadvanced', name:'JEE Advanced (India)', flag:'🇮🇳'}],
  'cat':        [{id:'jamb', name:'JAMB (Nigeria)', flag:'🇳🇬'}],
  'clat':       [{id:'lat', name:'LAT (Pakistan)', flag:'🇵🇰'}],
  'lat':        [{id:'clat', name:'CLAT (India)', flag:'🇮🇳'}],
  'upsc':       [{id:'css', name:'CSS (Pakistan)', flag:'🇵🇰'}],
  'ssc-cgl':    [{id:'pts', name:'PTS (Pakistan)', flag:'🇵🇰'}],
  'nda':        [{id:'js1', name:'JS1 (Nigeria)', flag:'🇳🇬'}],
};
const relatedExams = EXAM_EQUIVALENTS[exam] || [];
---

<Layout title={title} description={description} canonical={canonicalUrl} image={ogImage} faqs={faqs} author={authorObj}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionPageJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <Navbar />
  <main id="main-content" class="flex-1">
    <!-- Header -->
    <section class="bg-surface-50 dark:bg-surface-950 border-b border-surface-200 dark:border-surface-800">
      <div class="container-page py-10">
        <nav class="flex items-center gap-2 text-sm text-surface-500 mb-4" aria-label="Breadcrumb">
          <a href="/" class="hover:text-brand-600">Home</a>
          <span>›</span>
          <a href="/roadmap" class="hover:text-brand-600">Roadmap</a>
          <span>›</span>
          <a href={`/roadmap?exam=${exam}`} class="hover:text-brand-600">{flag} {examName}</a>
          <span>›</span>
          <span class="text-surface-900 dark:text-surface-100">{subjectName}</span>
        </nav>
        <h1 class="heading-1 text-surface-900 dark:text-surface-50 mb-2">{subjectName} — {examName}</h1>
        <p class="text-surface-600 dark:text-surface-400">
          {subjectNotes.length} topics · Free, no signup required
        </p>
        <div class="mt-5 flex gap-3">
          <a href={`/roadmap?exam=${exam}`} class="btn-primary inline-flex items-center gap-2">
            → See Full Roadmap
          </a>
        </div>
      </div>
    </section>

    <!-- Topic grid -->
    <section class="container-page py-12">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {subjectNotes.map(note => (
          <a
            href={`/notes/${exam}/${subject}/${note.data.topic}`}
            class="group block bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-700 rounded-xl p-5 hover:border-brand-300 dark:hover:border-brand-700 hover:shadow-md transition-all"
          >
            <div class="flex items-start justify-between mb-2">
              <span class="text-xs font-mono text-surface-400 bg-surface-100 dark:bg-surface-800 px-2 py-0.5 rounded">
                {note.data.topic}
              </span>
              <span class="text-xs text-brand-600 dark:text-brand-400 font-medium">
                {note.data.weight}%
              </span>
            </div>
            <h2 class="font-semibold text-surface-900 dark:text-surface-100 group-hover:text-brand-600 dark:group-hover:text-brand-400 mb-1">
              {note.data.topicName}
            </h2>
            <p class="text-sm text-surface-500">Click to read notes →</p>
          </a>
        ))}
      </div>

      <!-- Other subjects in this exam -->
      {otherSubjects.length > 0 && (
        <div class="mt-10 border-t border-surface-200 dark:border-surface-700 pt-10">
          <h2 class="heading-3 text-surface-800 dark:text-surface-100 mb-4">More Subjects for {examName}</h2>
          <div class="flex flex-wrap gap-3">
            {otherSubjects.map(s => (
              <a href={`/notes/${exam}/${s.id}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-100 dark:bg-surface-800 border border-surface-200 dark:border-surface-700 hover:border-brand-300 dark:hover:border-brand-700 text-surface-700 dark:text-surface-300 text-sm transition-all">
                {s.name} →
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Equivalent exams abroad -->
      {relatedExams.length > 0 && (
        <div class="mt-8 border-t border-surface-200 dark:border-surface-700 pt-8">
          <h2 class="heading-3 text-surface-800 dark:text-surface-100 mb-2">🌍 Equivalent Exams in Other Countries</h2>
          <p class="text-sm text-surface-500 dark:text-surface-400 mb-4">
            The same field of study — accepted in other countries' universities.
          </p>
          <div class="flex flex-wrap gap-3">
            {relatedExams.map(rel => (
              <a href={`/notes/${rel.id}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-100 dark:bg-surface-800 border border-surface-200 dark:border-surface-700 hover:border-brand-300 dark:hover:border-brand-700 text-surface-700 dark:text-surface-300 text-sm transition-all">
                <span>{rel.flag}</span>
                <span>{rel.name}</span>
                <span class="text-surface-400">→</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="mt-12 bg-gradient-to-r from-brand-50 to-brand-100 dark:from-brand-950 dark:to-surface-900 border border-brand-200 dark:border-brand-800 rounded-2xl p-8 text-center">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-2">
          Want a personalised study plan?
        </h2>
        <p class="text-surface-600 dark:text-surface-400 mb-5 max-w-md mx-auto">
          Tell us your exam and available time — get an instant ranked roadmap of all {examName} topics.
        </p>
        <a href={`/roadmap?exam=${exam}`} class="btn-primary inline-flex items-center gap-2">
          Build My {examName} Roadmap →
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
