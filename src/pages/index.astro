    <!-- CTA -->
    <section class="relative overflow-hidden bg-gradient-to-r from-surface-950 via-brand-950 to-surface-950 py-16 sm:py-20">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] bg-brand-600/10 rounded-full blur-3xl" />
      </div>
      <div class="container-page relative z-10 text-center">
        <h2 class="heading-1 text-white mb-4">Ready to Study Smarter?</h2>
        <p class="text-lg text-surface-300 mb-8 max-w-xl mx-auto">
          Join students who planned their way to success. Free, instant, no signup.
        </p>
        <a href="/roadmap" class="btn-primary text-base px-8 py-3.5 shadow-lg shadow-brand-600/30 inline-flex items-center gap-2">
          Get Started Free
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </section>

  {/* WHY TRUST US */}
  <section class="bg-surface-50 dark:bg-surface-900 border-t border-surface-200 dark:border-surface-800 py-14">
    <div class="container-page">
      <p class="section-label text-center mb-3">Built on Transparency</p>
      <h2 class="heading-2 text-surface-900 dark:text-white text-center mb-10">
        Why Students Trust StudyRoadmap
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-4xl mx-auto">
        <div class="flex flex-col gap-2">
          <div class="w-10 h-10 rounded-lg bg-surface-100 dark:bg-surface-800 flex items-center justify-center text-lg">🏛️</div>
          <h3 class="font-semibold text-surface-900 dark:text-white text-sm">Independent & Unbiased</h3>
          <p class="text-xs text-surface-500 dark:text-surface-400 leading-relaxed">Not affiliated with any exam board, government, or coaching chain. Our recommendations are based purely on publicly available syllabus data — not promotional relationships.</p>
