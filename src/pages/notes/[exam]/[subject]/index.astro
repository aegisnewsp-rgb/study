---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  const subjects = [...new Set(allNotes.map(n => n.id.split('/').slice(0, 2).join('/')))];
  return subjects.map(slug => ({
    params: { exam: slug.split('/')[0], subject: slug.split('/')[1] },
    props: { slug },
  }));
}

const { slug } = Astro.props;
const allNotes = await getCollection('notes');
const subjectNotes = allNotes
  .filter(n => n.id.startsWith(slug + '/'))
  .sort((a, b) => a.data.topic.localeCompare(b.data.topic));

const { exam, subject } = Astro.params;
const firstNote = subjectNotes[0];
const examName = firstNote?.data.examName || exam;
const subjectName = firstNote?.data.subjectName || subject;
const flag = { india: '🇮🇳', pakistan: '🇵🇰', nigeria: '🇳🇬' }[firstNote?.data.country] || '🌍';

const title = `${subjectName} Study Notes — ${examName} | StudyRoadmap™`;
const description = `Free ${subjectName} study notes for ${examName}. ${subjectNotes.length} topics covered — concept explanations, formulas, problem-solving steps, and diagrams.`;
const canonicalUrl = `https://studyroadmap.in/notes/${exam}/${subject}`;
const siteUrl = 'https://studyroadmap.in';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Roadmap', item: `${siteUrl}/roadmap` },
    { '@type': 'ListItem', position: 3, name: examName, item: `${siteUrl}/roadmap?exam=${exam}` },
    { '@type': 'ListItem', position: 4, name: subjectName, item: canonicalUrl },
  ],
};
---

<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <Navbar />
  <main class="flex-1">
    <!-- Header -->
    <section class="bg-surface-50 dark:bg-surface-950 border-b border-surface-200 dark:border-surface-800">
      <div class="container-page py-10">
        <nav class="flex items-center gap-2 text-sm text-surface-500 mb-4" aria-label="Breadcrumb">
          <a href="/" class="hover:text-brand-600">Home</a>
          <span>›</span>
          <a href="/roadmap" class="hover:text-brand-600">Roadmap</a>
          <span>›</span>
          <a href={`/roadmap?exam=${exam}`} class="hover:text-brand-600">{flag} {examName}</a>
          <span>›</span>
          <span class="text-surface-900 dark:text-surface-100">{subjectName}</span>
        </nav>
        <h1 class="heading-1 text-surface-900 dark:text-surface-50 mb-2">{subjectName} — {examName}</h1>
        <p class="text-surface-600 dark:text-surface-400">
          {subjectNotes.length} topics · Free, no signup required
        </p>
        <div class="mt-5 flex gap-3">
          <a href={`/roadmap?exam=${exam}`} class="btn-primary inline-flex items-center gap-2">
            → See Full Roadmap
          </a>
        </div>
      </div>
    </section>

    <!-- Topic grid -->
    <section class="container-page py-12">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {subjectNotes.map(note => (
          <a
            href={`/notes/${note.slug}`}
            class="group block bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-700 rounded-xl p-5 hover:border-brand-300 dark:hover:border-brand-700 hover:shadow-md transition-all"
          >
            <div class="flex items-start justify-between mb-2">
              <span class="text-xs font-mono text-surface-400 bg-surface-100 dark:bg-surface-800 px-2 py-0.5 rounded">
                {note.data.topic}
              </span>
              <span class="text-xs text-brand-600 dark:text-brand-400 font-medium">
                {note.data.weight}%
              </span>
            </div>
            <h2 class="font-semibold text-surface-900 dark:text-surface-100 group-hover:text-brand-600 dark:group-hover:text-brand-400 mb-1">
              {note.data.topicName}
            </h2>
            <p class="text-sm text-surface-500">Click to read notes →</p>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-12 bg-gradient-to-r from-brand-50 to-brand-100 dark:from-brand-950 dark:to-surface-900 border border-brand-200 dark:border-brand-800 rounded-2xl p-8 text-center">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-50 mb-2">
          Want a personalised study plan?
        </h2>
        <p class="text-surface-600 dark:text-surface-400 mb-5 max-w-md mx-auto">
          Tell us your exam and available time — get an instant ranked roadmap of all {examName} topics.
        </p>
        <a href={`/roadmap?exam=${exam}`} class="btn-primary inline-flex items-center gap-2">
          Build My {examName} Roadmap →
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
