---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { ALL_EXAMS, getCountryFlag } from '../data/exams';

const SITE_URL = 'https://studyroadmap.in';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Exams', item: `${SITE_URL}/exams/` },
  ],
};

const examItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'All Competitive Exams on StudyRoadmap',
  description: `Browse ${ALL_EXAMS.length} competitive exams from India, Pakistan, Nigeria, and ${30} other countries. Each exam page includes syllabus, exam pattern, eligibility criteria, and free AI study roadmap.`,
  numberOfItems: ALL_EXAMS.length,
  itemListElement: ALL_EXAMS.slice(0, 20).map((exam, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: exam.examName || exam.examId,
    url: `${SITE_URL}/exams/${exam.examId}`,
    description: exam.description ? cleanText(exam.description).slice(0, 160) : undefined,
  })),
};

const SUBJECT_COLORS = ['#60a5fa','#34d399','#fb923c','#a78bfa','#f472b6','#14b8a6','#fbbf24','#f87171'];
function cleanText(s = '') { return s.replace(/\\n/g, ' ').replace(/\\/g, '').replace(/"/g, ''); }

const COUNTRY_LABELS: Record<string, { label: string; flag: string }> = {
  india:      { label: 'India',        flag: '🇮🇳' },
  pakistan:   { label: 'Pakistan',     flag: '🇵🇰' },
  nigeria:    { label: 'Nigeria',      flag: '🇳🇬' },
  bangladesh: { label: 'Bangladesh',   flag: '🇧🇩' },
  srilanka:   { label: 'Sri Lanka',    flag: '🇱🇰' },
  nepal:      { label: 'Nepal',        flag: '🇳🇵' },
  saudi:      { label: 'Saudi Arabia', flag: '🇸🇦' },
  uae:        { label: 'UAE',          flag: '🇦🇪' },
  southafrica:{ label: 'South Africa', flag: '🇿🇦' },
  kenya:      { label: 'Kenya',       flag: '🇰🇪' },
  ethiopia:   { label: 'Ethiopia',     flag: '🇪🇹' },
  ghana:      { label: 'Ghana',       flag: '🇬🇭' },
  uganda:     { label: 'Uganda',      flag: '🇺🇬' },
  tanzania:   { label: 'Tanzania',    flag: '🇹🇿' },
  russia:     { label: 'Russia',      flag: '🇷🇺' },
  china:      { label: 'China',       flag: '🇨🇳' },
  philippines:{ label: 'Philippines', flag: '🇵🇭' },
  indonesia:  { label: 'Indonesia',   flag: '🇮🇩' },
  malaysia:   { label: 'Malaysia',    flag: '🇲🇾' },
};

const byCountry = Object.fromEntries(
  Object.entries(COUNTRY_LABELS)
    .map(([code, { label, flag }]) => [
      code,
      { label, flag, exams: ALL_EXAMS.filter(e => e.country === code) },
    ])
    .filter(([, { exams }]) => exams.length > 0)
);

const EXAM_FAQS = [
  {
    question: 'How do I choose the right exam for me?',
    answer: 'Start by checking the eligibility criteria — your education level, age, and nationality determine which exams you can appear for. Then consider your career goals: medicine (NEET, MDCAT), engineering (JEE, ECAT), civil services (UPSC, SSC CGL), or business (CAT). StudyRoadmap can generate a personalised study plan for any exam you select.',
  },
  {
    question: 'What is the eligibility criteria for these exams?',
    answer: 'Eligibility varies by exam and country. Most Indian exams require 17+ years of age and completion of Class 12 (for undergraduate exams) or a bachelor\'s degree (for postgraduate). Pakistani exams like MDCAT require FSc or equivalent. Nigerian exams like JAMB require SSCE credit passes in five subjects. Always check the official exam website for the latest eligibility rules before applying.',
  },
  {
    question: 'Can I prepare for multiple exams at the same time?',
    answer: 'Yes — many students prepare for overlapping exams like JEE Main and UPSC Prelims simultaneously, or JEE and NEET. The key is to identify common syllabus areas (general science, mathematics, English) and build a unified study schedule. Use StudyRoadmap to generate roadmaps for each exam and look for topic overlap.',
  },
  {
    question: 'What is the best time to start preparing for competitive exams?',
    answer: 'Most students begin 6 to 12 months before the exam date. For board exam students (Class 12), starting integrated preparation alongside board studies in Class 11 is ideal. For UPSC or other graduate-level exams, 12 to 18 months of focused preparation is common. Use StudyRoadmap\'s duration selector to build a plan that fits your timeline.',
  },
  {
    question: 'Are these exams conducted online or offline?',
    answer: 'Most modern competitive exams are computer-based tests (CBT) conducted online at designated test centres. NEET, JEE Main, JEE Advanced, CAT, and CLAT are all online. Some exams like UPSC Mains are still pen-and-paper. Check the official exam notification for your specific exam mode and bring the required identification.',
  },
  {
    question: 'What documents do I need to register for these exams?',
    answer: 'Standard requirements include: a valid government-issued photo ID (Aadhaar card, CNIC, or National ID), recent passport-size photographs, your educational mark sheets or certificates, and the exam fee payment receipt. International students taking exams in India or Pakistan may also need a valid passport. Keep scanned copies ready for the online application portal.',
  },
];
---

<Layout
  title="Browse Exams — StudyRoadmap™"
  description={`Explore all ${ALL_EXAMS.length} competitive exams covered by StudyRoadmap™ — NEET, JEE, UPSC, MDCAT, JAMB, WAEC, Gaokao, and more across ${Object.keys(byCountry).length} countries.`}
  faqs={EXAM_FAQS}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(examItemList)} />
  <Navbar />

  <main id="main-content" class="flex-1">
    <section class="bg-surface-50 dark:bg-surface-950 border-b border-surface-200 dark:border-surface-800">
      <div class="container-page py-14 sm:py-20 text-center">
        <h1 class="heading-1 text-surface-900 dark:text-surface-50 mb-3">Browse Exams</h1>
        <p class="text-base sm:text-lg text-surface-600 dark:text-surface-400 max-w-xl mx-auto">
          {ALL_EXAMS.length} exams across {Object.keys(byCountry).length} countries. Select any exam to generate your personalised study roadmap — completely free.
        </p>
      </div>
    </section>

    <section class="container-page py-12 space-y-14">
      {Object.entries(byCountry).map(([code, { label, flag, exams }]) => (
        <div id={code}>
          <div class="flex items-center gap-3 mb-6">
            <span class="text-3xl">{flag}</span>
            <h2 class="heading-2 text-surface-900 dark:text-white">{label}</h2>
            <span class="text-sm text-surface-400 bg-surface-100 dark:bg-surface-800 px-2.5 py-1 rounded-full">
              {exams.length} exams
            </span>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {exams.map((exam, i) => (
              <a href={`/roadmap?exam=${exam.examId}`} class="card card-hover p-5 flex flex-col gap-3 group">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-semibold text-surface-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                    {exam.examName}
                  </h3>
                  <span class="text-xs font-medium px-2 py-1 rounded-full bg-surface-100 dark:bg-surface-800 text-surface-600 dark:text-surface-300 shrink-0">
                    {exam.subjects.length} subjects
                  </span>
                </div>

                {exam.description && (
                  <p class="text-xs text-surface-500 line-clamp-2">
                    {cleanText(exam.description)}
                  </p>
                )}

                {exam.examPattern && (
                  <p class="text-xs text-surface-400 line-clamp-1">
                    📋 {cleanText(exam.examPattern)}
                  </p>
                )}

                {exam.eligibility && (
                  <p class="text-xs text-emerald-600 dark:text-emerald-400 font-medium line-clamp-1">
                    ✓ {cleanText(exam.eligibility).substring(0, 55)}{cleanText(exam.eligibility).length > 55 ? '…' : ''}
                  </p>
                )}

                <div class="flex flex-wrap gap-1.5 mt-auto pt-1">
                  {exam.subjects.slice(0, 3).map((s, si) => (
                    <span
                      class="text-xs px-2 py-0.5 rounded-full font-medium"
                      style={`background-color: ${SUBJECT_COLORS[si % SUBJECT_COLORS.length]}20; color: ${SUBJECT_COLORS[si % SUBJECT_COLORS.length]};`}
                    >
                      {s.name}
                    </span>
                  ))}
                  {exam.subjects.length > 3 && (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-surface-100 dark:bg-surface-800 text-surface-500">
                      +{exam.subjects.length - 3}
                    </span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  </main>

  <Footer />
</Layout>
