  {/* Latest Exam Updates — fresh crawlable news */}
  {latestNews.length > 0 && (
    <section class="bg-surface-50 dark:bg-surface-950 border-t border-surface-200 dark:border-surface-800">
      <div class="container-page py-12">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-black text-surface-900 dark:text-white">
            Latest Exam Updates
          </h2>
          <span class="text-sm text-surface-400">Updated hourly · sourced from official exam boards</span>
        </div>
        <div class="grid gap-3">
          {latestNews.map((item) => {
            const flag = countryFlags[item.country?.toLowerCase()] || '📢';
            return (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer sponsored"
                class="group flex items-start gap-3 p-4 bg-white dark:bg-surface-900 rounded-xl border border-surface-200 dark:border-surface-800 hover:border-brand-300 dark:hover:border-brand-700 hover:shadow-md transition-all"
              >
                <span class="text-xl flex-shrink-0 mt-0.5">{flag}</span>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-surface-700 dark:text-surface-200 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors text-sm leading-snug">
                    {item.title}
                  </p>
                  <p class="text-xs text-surface-400 mt-1">
                    {item.source}
                    {item.age ? ` · ${item.age}` : ''}
                  </p>
                </div>
                <svg class="w-4 h-4 text-surface-300 flex-shrink-0 mt-1 group-hover:text-brand-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
