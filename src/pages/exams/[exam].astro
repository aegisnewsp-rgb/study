---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { ALL_EXAMS, getCountryFlag } from '../../data/exams';
import { EXAM_FAQS } from '../../data/exam-faqs';

export async function getStaticPaths() {
  return ALL_EXAMS
    .filter(e => e && e.examId)
    .map(exam => ({
      params: { exam: exam.examId },
      props: { exam },
    }));
}

const { exam } = Astro.props;
const SITE_URL = 'https://studyroadmap.in';
const flag = getCountryFlag(exam.country) || '🌍';

// Live-exam banners — show a timely alert for exams happening right now
// (Add entries for upcoming exams with dates)
const LIVE_EXAMS: Record<string, { label: string; message: string; cta: string; ctaUrl: string; }> = {
};

const liveExam = LIVE_EXAMS[exam.examId];

const countryLabels: Record<string, string> = {
  india: 'India', pakistan: 'Pakistan', nigeria: 'Nigeria',
  bangladesh: 'Bangladesh', srilanka: 'Sri Lanka', nepal: 'Nepal',
  china: 'China', ethiopia: 'Ethiopia', ghana: 'Ghana', kenya: 'Kenya',
  malaysia: 'Malaysia', indonesia: 'Indonesia', philippines: 'Philippines',
  southafrica: 'South Africa', saudi: 'Saudi Arabia', uae: 'UAE',
};

const geoRegionMap: Record<string, string> = {
  india: 'IN', pakistan: 'PK', nigeria: 'NG', bangladesh: 'BD',
  kenya: 'KE', southafrica: 'ZA', uae: 'AE', malaysia: 'MY',
};

const hreflangMap: Record<string, string> = {
  india: 'en-IN', pakistan: 'en-PK', nigeria: 'en-NG', bangladesh: 'en-BD',
  kenya: 'en-KE', southafrica: 'en-ZA', uae: 'en-AE', malaysia: 'en-MY',
};

const examName = exam.examName || exam.examId;
const countryName = countryLabels[exam.country] || exam.country;

// Rich exam description
const fullDescription = exam.description
  ? exam.description.replace(/\\n/g, ' ').replace(/\\/g, '').replace(/"/g, '')
  : `Comprehensive ${examName} study guide and exam preparation resources. Free AI-powered study roadmap generator with personalized study plans based on your available time.`;

const fullExamPattern = exam.examPattern
  ? exam.examPattern.replace(/\\n/g, ' ').replace(/\\/g, '').replace(/"/g, '')
  : '';

const fullEligibility = exam.eligibility
  ? exam.eligibility.replace(/\\n/g, ' ').replace(/\\/g, '').replace(/"/g, '')
  : '';

const title = `${examName} — Exam Pattern, Eligibility & Study Plan | StudyRoadmap™`;
const description = `${fullDescription} Covers exam pattern, eligibility criteria, syllabus topics, and how to generate a free personalised study roadmap in minutes.`;
const canonicalUrl = `${SITE_URL}/exams/${exam.examId}`;

const authorObj = {
  name: "StudyRoadmap Editorial Team",
  jobTitle: "Curriculum Editors",
  affiliation: "StudyRoadmap",
  url: "https://studyroadmap.in/about",
};

// Schemas
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Exams', item: `${SITE_URL}/exams/` },
    { '@type': 'ListItem', position: 3, name: examName, item: canonicalUrl },
  ],
};

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `How to Prepare for ${examName} in Record Time`,
  description: `A structured 3-step approach to cracking ${examName} using an AI-powered personalised study roadmap.`,
  step: [
    {
      '@type': 'HowToStep',
      name: 'Step 1 — Generate your personalised roadmap',
      text: `Select "${examName}" on StudyRoadmap, choose your available preparation time, and get an instant AI-generated study plan prioritised by topic weightage for ${examName}.`,
      url: `${SITE_URL}/roadmap?exam=${exam.examId}`,
    },
    {
      '@type': 'HowToStep',
      name: 'Step 2 — Study topic by topic',
      text: `Follow your roadmap and open free study notes for each topic. Notes include concept explanations, key formulas, exam-level practice questions, and three depth tiers (Quick, Standard, Deep) based on your time.`,
      url: `${SITE_URL}/notes/${exam.examId}/`,
    },
    {
      '@type': 'HowToStep',
      name: 'Step 3 — Track progress and revise',
      text: `Mark topics as completed in your roadmap. The AI roadmap adapts to your pace and ensures you cover all high-weightage topics before exam day.`,
      url: `${SITE_URL}/roadmap?exam=${exam.examId}`,
    },
  ],
};

// Exam-specific FAQ — rich content from exam-faqs.ts, falls back to generic if not found
const examSpecificFAQs = EXAM_FAQS[exam.examId] || null;
const examFAQs = examSpecificFAQs || [
  {
    question: `What is ${examName} and who conducts it?`,
    answer: `${examName} is a competitive examination for students in ${countryName}. For detailed information on the conducting authority, eligibility criteria, and exam schedule, visit the official source or check the eligibility section below.`,
  },
  {
    question: `What is the exam pattern for ${examName}?`,
    answer: fullExamPattern
      || `The ${examName} exam consists of multiple-choice questions across subjects. The exact number of questions, marking scheme (+/-), and time duration vary by the latest official notification. Generate a free study roadmap to focus on the most frequently tested topics.`,
  },
  {
    question: `What are the eligibility criteria for ${examName}?`,
    answer: fullEligibility
      || `Eligibility for ${examName} typically requires the candidate to have passed the qualifying examination (Class 12 for undergraduate exams, bachelor's degree for postgraduate exams) with the required percentage. Specific age limits and subject requirements apply. Check the official notification for your category's exact requirements.`,
  },
  {
    question: `How can I create a study plan for ${examName}?`,
    answer: `Simply select "${examName}" on StudyRoadmap, enter the time you have available (from 1 hour to 2 years), and the AI will generate a personalised study roadmap prioritising topics by their exam weightage. Each topic links directly to free study notes. No signup required.`,
  },
  {
    question: `What subjects are covered in ${examName}?`,
    answer: exam.subjects && exam.subjects.length > 0
      ? `${examName} covers ${exam.subjects.map((s: any) => s.name).join(', ')}. Use the study roadmap to prioritise subjects based on your strengths and the exam's subject-wise weightage.`
      : `${examName} covers multiple subjects. Check the detailed syllabus and generate a free personalised roadmap to know which topics to focus on first.`,
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: examFAQs.map(f => ({
    '@type': 'Question',
    name: f.question,
    about: {
      '@type': 'EducationalLevel',
      'name': exam.educationalLevel || 'Higher Secondary',
      'description': `${examName} exam preparation for students in ${countryName}.`
    },
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

// Course schema for exam pages
const courseJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  'name': `${examName} Study Roadmap`,
  'description': `Comprehensive ${examName} preparation course covering syllabus, exam pattern, eligibility, and topic-wise study plan.`,
  'provider': {
    '@type': 'Organization',
    'name': 'StudyRoadmap',
    'url': 'https://studyroadmap.in',
  },
  'educationalLevel': exam.educationalLevel || 'Higher Secondary',
  'inLanguage': 'en',
  'audience': {
    '@type': 'Audience',
    'audienceType': `Students preparing for ${examName} in ${countryName}`
  },
};

// Subject data for display
const subjectList = exam.subjects || [];
const totalTopics = subjectList.reduce((acc: number, s: any) => acc + (s.topics?.length || 0), 0);
const durations = Object.keys(exam.durations || {}).slice(0, 6);

// Find related exams (same country, different exam)
const relatedExams = ALL_EXAMS
  .filter(e => e && e.examId !== exam.examId && e.country === exam.country)
  .slice(0, 4);

// Exam pathway mappings — cross-links between logically related exams
const pathwayMap: Record<string, Array<{ examId: string; label: string; reason: string }>> = {
  // India
  'jeemain': [
    { examId: 'jeeadvanced', label: 'JEE Advanced', reason: 'for top-tier engineering colleges' },
    { examId: 'cuet', label: 'CUET', reason: 'shared physics & chemistry syllabus' },
  ],
  'jeeadvanced': [
    { examId: 'jeemain', label: 'JEE Main', reason: 'to qualify and attempt JEE Advanced' },
    { examId: 'bitsat', label: 'BITSAT', reason: 'alternate engineering entrance' },
  ],
  'neet': [
    { examId: 'cuet', label: 'CUET', reason: 'overlapping biology & chemistry syllabus' },
    { examId: 'aiims-mbbs', label: 'AIIMS MBBS', reason: 'top medical college admissions' },
  ],
  'cuet': [
    { examId: 'neet', label: 'NEET', reason: 'shared biology & chemistry preparation' },
    { examId: 'jeemain', label: 'JEE Main', reason: 'overlapping physics & chemistry' },
  ],
  'upsc': [
    { examId: 'ssc-cgl', label: 'SSC CGL', reason: 'overlapping GK, polity & current affairs' },
    { examId: 'up-psc', label: 'UPPSC', reason: 'state-level civil services exam' },
  ],
  'ssc-cgl': [
    { examId: 'upsc', label: 'UPSC CSE', reason: 'overlapping GK and reasoning topics' },
    { examId: 'bpsc', label: 'BPSC', reason: 'state civil services with shared syllabus' },
  ],
  'cat': [
    { examId: 'xat', label: 'XAT', reason: 'alternative MBA entrance exam' },
    { examId: 'snap', label: 'SNAP', reason: 'MBA aspirants often attempt multiple exams' },
  ],
  'gate': [
    { examId: 'jeemain', label: 'JEE Main', reason: 'engineering fundamentals refresh' },
    { examId: 'ugc-net', label: 'UGC NET', reason: 'career path in academia' },
  ],
  // Pakistan
  'mdcat': [
    { examId: 'ecat', label: 'ECAT', reason: 'engineering parallel exam path' },
    { examId: 'nat-i', label: 'NAT-I', reason: 'overlapping aptitude topics' },
  ],
  'ecat': [
    { examId: 'mdcat', label: 'MDCAT', reason: 'medical vs engineering — choose your path' },
    { examId: 'mcat', label: 'MCAT', reason: 'alternate medical college test' },
  ],
  'nat-i': [
    { examId: 'hat-ug', label: 'HAT-UG', reason: 'similar aptitude & verbal reasoning' },
    { examId: 'mdcat', label: 'MDCAT', reason: 'broaden university options' },
  ],
  'hat-ug': [
    { examId: 'nat-i', label: 'NAT-I', reason: 'equivalent aptitude test for admissions' },
    { examId: 'ecat', label: 'ECAT', reason: 'add engineering to your options' },
  ],
  // Nigeria
  'jamb': [
    { examId: 'waec', label: 'WAEC', reason: 'WAEC syllabus underpins JAMB questions' },
    { examId: 'neco', label: 'NECO', reason: 'alternative secondary school certification' },
  ],
  'waec': [
    { examId: 'jamb', label: 'JAMB', reason: 'JAMB uses WAEC syllabus as foundation' },
    { examId: 'neco', label: 'NECO', reason: 'dual certification strengthens university profile' },
  ],
  'neco': [
    { examId: 'waec', label: 'WAEC', reason: 'same board, widely accepted alongside NECO' },
    { examId: 'jamb', label: 'JAMB', reason: 'qualifying exam for Nigerian universities' },
  ],
};

// Resolve pathway exams that actually exist in ALL_EXAMS
const pathwayExamEntries = pathwayMap[exam.examId] || [];
const pathwayExams = pathwayExamEntries
  .filter(p => ALL_EXAMS.some(e => e && e.examId === p.examId))
  .map(p => ({ ...p, exam: ALL_EXAMS.find(e => e && e.examId === p.examId) }));

// Wikipedia citations for E-E-A-T (Experience, Expertise, Authoritativeness, Trustworthiness)
const EXAM_WIKI_CITATIONS: Record<string, Array<{ label: string; url: string; note?: string }>> = {
  'mdcat': [
    { label: 'Medical and Dental College Admission Test — Wikipedia', url: 'https://en.wikipedia.org/wiki/Medical_and_Dental_College_Admission_Test', note: 'Overview of MDCAT format, conducting bodies, and syllabus scope' },
    { label: 'Pakistan Medical Commission — Wikipedia', url: 'https://en.wikipedia.org/wiki/Pakistan_Medical_Commission', note: 'Official regulatory authority for MDCAT in Pakistan' },
  ],
  'jamb': [
    { label: 'Joint Admissions and Matriculation Board — Wikipedia', url: 'https://en.wikipedia.org/wiki/Joint_Admissions_and_Matriculation_Board', note: 'Official body conducting JAMB UTME in Nigeria' },
    { label: 'Unified Tertiary Matriculation Examination — Wikipedia', url: 'https://en.wikipedia.org/wiki/Unified_Tertiary_Matriculation_Examination', note: 'Format, subjects, and scoring system for JAMB exams' },
  ],
  'waec': [
    { label: 'West African Examinations Council — Wikipedia', url: 'https://en.wikipedia.org/wiki/West_African_Examinations_Council', note: "WAEC's role, history, and exam coverage across West Africa" },
    { label: 'West African Senior School Certificate Examination — Wikipedia', url: 'https://en.wikipedia.org/wiki/West_African_Senior_School_Certificate_Examination', note: 'Senior school certification exam administered by WAEC' },
  ],
  'kuccps': [
    { label: 'Kenya Universities and Colleges Central Placement Service — Wikipedia', url: 'https://en.wikipedia.org/wiki/Kenya_Universities_and_Colleges_Central_Placement_Service', note: 'Government agency managing university admissions placement in Kenya' },
    { label: 'University education in Kenya — Wikipedia', url: 'https://en.wikipedia.org/wiki/University_education_in_Kenya', note: "Overview of Kenya's university system and admission pathways" },
  ],
};
const wikiCitations = EXAM_WIKI_CITATIONS[exam.examId] || [];
---

<Layout
  title={title}
  description={description}
  canonical={canonicalUrl}
  image={`/og-notes/exam-${exam.examId}.jpg`}
  author={authorObj}
  geoRegion={geoRegionMap[exam.country]}
  hreflang={hreflangMap[exam.country]}
  countryName={countryName}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(courseJsonLd)} />

  <Navbar />

  <main id="main-content" class="flex-1">

    {/* Live exam alert banner */}
    {liveExam && (
      <div class="bg-red-600 text-white">
        <div class="container-page py-3 flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-4">
          <span class="shrink-0 text-xs font-bold tracking-widest">{liveExam.label}</span>
          <p class="text-sm flex-1">{liveExam.message}</p>
          <a href={liveExam.ctaUrl} class="shrink-0 inline-flex items-center gap-1.5 bg-white text-red-600 font-bold text-sm px-4 py-1.5 rounded-lg hover:bg-red-50 transition-colors">
            {liveExam.cta} →
          </a>
        </div>
      </div>
    )}

    <!-- Hero -->
    <section class="bg-gradient-to-br from-surface-50 to-brand-50 dark:from-surface-950 dark:to-surface-900 border-b border-surface-200 dark:border-surface-800">
      <div class="container-page py-12 md:py-16">
        <nav class="flex items-center gap-2 text-sm text-surface-500 dark:text-surface-400 mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a>
          <span>›</span>
          <a href="/exams/" class="hover:text-brand-600 dark:hover:text-brand-400">Exams</a>
          <span>›</span>
          <span class="text-surface-700 dark:text-surface-200">{examName}</span>
        </nav>

        <div class="flex items-start gap-4 mb-4">
          <span class="text-4xl">{flag}</span>
          <div>
            <h1 class="text-3xl md:text-4xl font-black text-surface-900 dark:text-white mb-2">
              {examName}
            </h1>
            <p class="text-surface-500 dark:text-surface-400 text-sm">
              {countryName} · {subjectList.length} subjects · {totalTopics} topics
              {exam.lastUpdated ? ` · Updated ${exam.lastUpdated}` : ''}
            </p>
          </div>
        </div>

        {fullDescription && (
          <p class="text-surface-600 dark:text-surface-300 text-lg leading-relaxed max-w-3xl mb-8">
            {fullDescription}
          </p>
        )}

        <div class="flex flex-wrap gap-3">
          <a
            href={`${SITE_URL}/roadmap?exam=${exam.examId}`}
            class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold px-6 py-3 rounded-xl transition-colors shadow-lg shadow-brand-600/20"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            Generate Free Roadmap
          </a>
          <a
            href={`${SITE_URL}/notes/${exam.examId}/`}
            class="inline-flex items-center gap-2 bg-surface-100 dark:bg-surface-800 hover:bg-surface-200 dark:hover:bg-surface-700 text-surface-700 dark:text-surface-200 font-semibold px-6 py-3 rounded-xl transition-colors border border-surface-200 dark:border-surface-700"
          >
            Browse Study Notes →
          </a>
        </div>
      </div>
    </section>

    <!-- Exam Details -->
    {(fullExamPattern || fullEligibility) && (
      <section class="container-page py-10 grid md:grid-cols-2 gap-8">
        {fullExamPattern && (
          <div class="bg-surface-50 dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 p-6">
            <h2 class="text-lg font-bold text-surface-900 dark:text-white mb-3 flex items-center gap-2">
              <span class="text-xl">📋</span> Exam Pattern
            </h2>
            <p class="text-surface-600 dark:text-surface-300 leading-relaxed text-sm">{fullExamPattern}</p>
          </div>
        )}
        {fullEligibility && (
          <div class="bg-surface-50 dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 p-6">
            <h2 class="text-lg font-bold text-surface-900 dark:text-white mb-3 flex items-center gap-2">
              <span class="text-xl">✅</span> Eligibility Criteria
            </h2>
            <p class="text-surface-600 dark:text-surface-300 leading-relaxed text-sm">{fullEligibility}</p>
          </div>
        )}
      </section>
    )}

    <!-- Subject Cards -->
    {subjectList.length > 0 && (
      <section class="container-page py-10">
        <h2 class="text-2xl font-bold text-surface-900 dark:text-white mb-6">
          Subjects & Topics Covered
          <span class="text-surface-400 font-normal text-base ml-2">— {totalTopics} topics across {subjectList.length} subjects</span>
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {subjectList.map((subject: any) => (
            <a
              href={`${SITE_URL}/notes/${exam.examId}/${subject.id}/`}
              class="group bg-surface-50 dark:bg-surface-900 rounded-xl border border-surface-200 dark:border-surface-800 p-5 hover:border-brand-300 dark:hover:border-brand-700 hover:shadow-md transition-all"
            >
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-3">
                  <div
                    class="w-3 h-3 rounded-full flex-shrink-0"
                    style={`background-color: ${subject.color || '#60a5fa'}`}
                  />
                  <h3 class="font-bold text-surface-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                    {subject.name}
                  </h3>
                </div>
                <span class="text-xs text-surface-400 group-hover:text-brand-600 transition-colors">→</span>
              </div>
              <p class="text-sm text-surface-500 dark:text-surface-400">
                {subject.topics?.length || 0} topics
                {subject.topics?.slice(0, 3).map((t: any) => (
                  <span class="inline-block mr-1">· {t.name}</span>
                ))}
                {(subject.topics?.length || 0) > 3 && <span class="text-surface-400">+ more</span>}
              </p>
            </a>
          ))}
        </div>
        <div class="mt-6 text-center">
          <a
            href={`${SITE_URL}/roadmap?exam=${exam.examId}`}
            class="inline-flex items-center gap-2 text-brand-600 dark:text-brand-400 font-semibold hover:underline"
          >
            Generate your personalised {examName} roadmap →
          </a>
        </div>
      </section>
    )}

    <!-- Roadmap Duration CTA -->
    <section class="bg-brand-600 dark:bg-brand-900">
      <div class="container-page py-10">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div>
            <h2 class="text-2xl font-black text-white mb-2">
              Build Your {examName} Study Plan in Minutes
            </h2>
            <p class="text-brand-100 text-sm">
              Free, instant, no signup. Choose your duration and get a prioritised roadmap.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            {durations.map((d: string) => (
              <a
                href={`${SITE_URL}/roadmap?exam=${exam.examId}&duration=${d}`}
                class="bg-white/10 hover:bg-white/20 text-white font-bold px-4 py-2 rounded-lg text-sm transition-colors"
              >
                {d}
              </a>
            ))}
            <a
              href={`${SITE_URL}/roadmap?exam=${exam.examId}`}
              class="bg-white text-brand-700 font-bold px-5 py-2 rounded-lg text-sm hover:bg-brand-50 transition-colors"
            >
              All Durations →
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Related Exams from the same country */}
    {relatedExams.length > 0 && (
      <section class="container-page py-10">
        <h2 class="text-xl font-bold text-surface-900 dark:text-white mb-5">
          More Exams in {flag} {countryName}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {relatedExams.map((rel) => (
            <a
              href={`${SITE_URL}/exams/${rel.examId}/`}
              class="group bg-surface-50 dark:bg-surface-900 rounded-xl border border-surface-200 dark:border-surface-800 p-4 hover:border-brand-300 dark:hover:border-brand-700 hover:shadow-md transition-all"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="text-lg">{getCountryFlag(rel.country) || '📚'}</span>
                <h3 class="font-bold text-surface-800 dark:text-surface-100 text-sm group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                  {(rel as any).examName || rel.examId}
                </h3>
              </div>
              {rel.description ? (
                <p class="text-xs text-surface-500 dark:text-surface-400 line-clamp-2">
                  {rel.description.replace(/\\n/g, ' ').replace(/\\/g, '').slice(0, 100)}
                </p>
              ) : null}
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Exam-Specific FAQ — rich content, only shown when exam-specific data is available */}
    {examSpecificFAQs && examSpecificFAQs.length > 0 && (
      <section class="container-page py-12 border-t border-surface-200 dark:border-surface-800">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xl">❓</span>
          <h2 class="text-xl font-bold text-surface-900 dark:text-white">
            Frequently Asked Questions — {examName}
          </h2>
        </div>
        <p class="text-sm text-surface-500 dark:text-surface-400 mb-8">
          Everything you need to know about {examName}. Scroll down for the complete study guide.
        </p>
        <div class="grid gap-3 max-w-3xl">
          {examSpecificFAQs.map((faq: any, i: number) => (
            <details class="group bg-surface-50 dark:bg-surface-900 rounded-xl border border-surface-200 dark:border-surface-800 overflow-hidden">
              <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none select-none">
                <span class="font-semibold text-surface-900 dark:text-white text-sm group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors pr-4">
                  {faq.question}
                </span>
                <span class="shrink-0 text-surface-400 group-open:rotate-180 transition-transform">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </span>
              </summary>
              <div class="px-5 pb-5 text-sm text-surface-600 dark:text-surface-300 leading-relaxed border-t border-surface-100 dark:border-surface-800 pt-3">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
        <p class="text-sm text-surface-400 dark:text-surface-500 mt-6">
          Generating roadmap for {examName}? <a href={`/roadmap?exam=${exam.examId}`} class="text-brand-600 dark:text-brand-400 hover:underline font-medium">Get your free personalised study plan →</a>
        </p>
      </section>
    )}

    {/* Related Exams by Pathway — cross-links to logically related exams */}
    {pathwayExams.length > 0 && (
      <section class="container-page py-10 border-t border-surface-200 dark:border-surface-800">
        <div class="flex items-center gap-3 mb-5">
          <span class="text-xl">🔗</span>
          <h2 class="text-xl font-bold text-surface-900 dark:text-white">
            Related Exams by Pathway
          </h2>
        </div>
        <p class="text-sm text-surface-500 dark:text-surface-400 mb-6">
          Students preparing for {examName} often also consider these exams for syllabus overlap or the next step in their journey.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {pathwayExams.map((p) => (
            <a
              href={`${SITE_URL}/exams/${p.examId}/`}
              class="group flex items-start gap-4 bg-surface-50 dark:bg-surface-900 rounded-xl border border-surface-200 dark:border-surface-800 p-5 hover:border-brand-300 dark:hover:border-brand-700 hover:shadow-md transition-all"
            >
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-lg">{getCountryFlag(p.exam!.country) || '📚'}</span>
                  <h3 class="font-bold text-surface-800 dark:text-surface-100 text-sm group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                    {p.exam!.examName || p.examId}
                  </h3>
                </div>
                <p class="text-xs text-brand-600 dark:text-brand-400 font-medium">
                  {p.reason}
                </p>
              </div>
              <span class="text-surface-400 group-hover:text-brand-600 transition-colors mt-1">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- How It Works -->
    <section class="container-page py-12">
      <h2 class="text-2xl font-bold text-surface-900 dark:text-white mb-8 text-center">
        How to Prepare for {examName}
      </h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="w-12 h-12 bg-brand-100 dark:bg-brand-900 rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-black text-brand-600 dark:text-brand-400">1</div>
          <h3 class="font-bold text-surface-900 dark:text-white mb-2">Generate Your Roadmap</h3>
          <p class="text-surface-500 dark:text-surface-400 text-sm">Select your exam, choose available time — get an instant AI prioritised study plan.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-brand-100 dark:bg-brand-900 rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-black text-brand-600 dark:text-brand-400">2</div>
          <h3 class="font-bold text-surface-900 dark:text-white mb-2">Study Topic by Topic</h3>
          <p class="text-surface-500 dark:text-surface-400 text-sm">Open free notes for each topic, chosen by your roadmap. Three depth tiers: Quick, Standard, Deep.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-brand-100 dark:bg-brand-900 rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-black text-brand-600 dark:text-brand-400">3</div>
          <h3 class="font-bold text-surface-900 dark:text-white mb-2">Track & Revise</h3>
          <p class="text-surface-500 dark:text-surface-400 text-sm">Mark topics complete as you go. Your roadmap adapts to your pace and keeps high-weightage topics first.</p>
        </div>
      </div>
    </section>

    <!-- Exam Info Table -->
    <section class="container-page pb-12">
      <div class="bg-surface-50 dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 overflow-hidden">
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-surface-200 dark:border-surface-800">
              <td class="px-5 py-3 font-semibold text-surface-700 dark:text-surface-300 w-40">Exam Name</td>
              <td class="px-5 py-3 text-surface-900 dark:text-surface-100">{examName}</td>
            </tr>
            <tr class="border-b border-surface-200 dark:border-surface-800">
              <td class="px-5 py-3 font-semibold text-surface-700 dark:text-surface-300">Country</td>
              <td class="px-5 py-3 text-surface-900 dark:text-surface-100">{flag} {countryName}</td>
            </tr>
            <tr class="border-b border-surface-200 dark:border-surface-800">
              <td class="px-5 py-3 font-semibold text-surface-700 dark:text-surface-300">Subjects</td>
              <td class="px-5 py-3 text-surface-900 dark:text-surface-100">{subjectList.map((s: any) => s.name).join(', ')}</td>
            </tr>
            <tr class="border-b border-surface-200 dark:border-surface-800">
              <td class="px-5 py-3 font-semibold text-surface-700 dark:text-surface-300">Total Topics</td>
              <td class="px-5 py-3 text-surface-900 dark:text-surface-100">{totalTopics}</td>
            </tr>
            {exam.officialSource && (
              <tr class="border-b border-surface-200 dark:border-surface-800">
                <td class="px-5 py-3 font-semibold text-surface-700 dark:text-surface-300">Official Source</td>
                <td class="px-5 py-3">
                  <a href={exam.officialSource} target="_blank" rel="noopener noreferrer" class="text-brand-600 dark:text-brand-400 hover:underline">
                    {exam.officialSource}
                  </a>
                </td>
              </tr>
            )}
            {exam.lastUpdated && (
              <tr>
                <td class="px-5 py-3 font-semibold text-surface-700 dark:text-surface-300">Last Updated</td>
                <td class="px-5 py-3 text-surface-500 dark:text-surface-400">{exam.lastUpdated}</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </section>

    {/* Wikipedia Citations — E-E-A-T Sources & References */}
    {wikiCitations.length > 0 && (
      <section class="container-page pb-4 pt-8 border-t border-surface-200 dark:border-surface-800">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-base">📚</span>
          <h2 class="text-base font-bold text-surface-700 dark:text-surface-300">
            Sources & References
          </h2>
        </div>
        <p class="text-xs text-surface-400 dark:text-surface-500 mb-4 leading-relaxed">
          The following Wikipedia articles provide authoritative background on {examName} and its exam ecosystem. They are cited for E-E-A-T purposes to support the accuracy of the information presented on this page.
        </p>
        <ol class="space-y-2">
          {wikiCitations.map((cite, i) => (
            <li class="flex gap-3 text-xs">
              <span class="shrink-0 text-surface-300 dark:text-surface-600 font-mono select-none">[{i + 1}]</span>
              <div>
                <a
                  href={cite.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-brand-600 dark:text-brand-400 hover:underline font-medium"
                >
                  {cite.label}
                </a>
                {cite.note && (
                  <span class="text-surface-400 dark:text-surface-500"> — {cite.note}</span>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

  </main>

  <Footer />
</Layout>
