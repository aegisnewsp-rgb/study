---
import { getCollection, render } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  return allNotes.map(note => ({
    params: {
      exam: note.id.split('/')[0],
      subject: note.id.split('/')[1],
      topic: note.id.split('/')[2],
    },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

// SEO
const { exam, examName, subject, subjectName, topic, topicName, weight, country, diagramPrompt } = note.data;

const title = `${topicName} — ${subjectName} | ${examName} Study Notes`;
const description = `Free ${topicName} study notes for ${examName}. Covers concept, formulas, problem-solving steps, and a diagram. Part of the ${examName} study roadmap on StudyRoadmap™.`;
const canonicalUrl = `https://studyroadmap.in/notes/${note.id}`;
const ogImage = `/og-notes/${exam}-${subject}-${topic}.jpg`;
const siteUrl = 'https://studyroadmap.in';

// Related notes: same exam + subject, different topic
const allNotes = await getCollection('notes');
const sameExamSubject = allNotes.filter(n => {
  const parts = n.id.split('/');
  return parts[0] === note.id.split('/')[0] && parts[1] === note.id.split('/')[1] && parts[2] !== note.id.split('/')[2];
}).slice(0, 5);

// Country flag
const countryFlags: Record<string, string> = { india: '🇮🇳', pakistan: '🇵🇰', nigeria: '🇳🇬' };
const flag = countryFlags[country] || '🌍';

const faqs = [
  {
    question: `What is ${topicName} in ${examName}?`,
    answer: `${topicName} is a topic in the ${subjectName} syllabus of ${examName}. It carries a weight of ${weight}% in the exam. Our notes cover the key concepts, formulas, and problem-solving approaches you need to master this topic.`,
  },
  {
    question: `How do these notes help with ${examName} preparation?`,
    answer: `These notes are designed to be part of your personalised ${examName} study roadmap. Each topic is structured with concept explanations, formulas, problem-solving steps, and common mistakes to avoid. Use them alongside your roadmap for maximum effect.`,
  },
  {
    question: `Is this really free?`,
    answer: `Yes — all StudyRoadmap™ content is completely free. No account required, no signup, no email. Just open the notes and start studying.`,
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'StudyRoadmap',
  url: siteUrl,
  sameAs: [],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Roadmap', item: `${siteUrl}/roadmap` },
    { '@type': 'ListItem', position: 3, name: `${examName}`, item: `${siteUrl}/roadmap?exam=${exam}` },
    { '@type': 'ListItem', position: 4, name: subjectName, item: `${siteUrl}/notes/${exam}/${subject}` },
    { '@type': 'ListItem', position: 5, name: topicName, item: canonicalUrl },
  ],
};
---

<Layout title={title} description={description} canonical={canonicalUrl} image={ogImage} faqs={faqs}>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

  <Navbar />
  <main class="flex-1">
    <!-- Breadcrumb -->
    <div class="bg-surface-50 dark:bg-surface-950 border-b border-surface-200 dark:border-surface-800">
      <div class="container-page py-3">
        <nav class="flex items-center gap-2 text-sm text-surface-500 dark:text-surface-400" aria-label="Breadcrumb">
          <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a>
          <span>›</span>
          <a href="/roadmap" class="hover:text-brand-600 dark:hover:text-brand-400">Roadmap</a>
          <span>›</span>
          <a href={`/roadmap?exam=${exam}`} class="hover:text-brand-600 dark:hover:text-brand-400">{flag} {examName}</a>
          <span>›</span>
          <a href={`/notes/${exam}/${subject}`} class="hover:text-brand-600 dark:hover:text-brand-400">{subjectName}</a>
          <span>›</span>
          <span class="text-surface-900 dark:text-surface-100">{topicName}</span>
        </nav>
      </div>
    </div>

    <!-- Note header -->
    <section class="bg-surface-50 dark:bg-surface-950 border-b border-surface-200 dark:border-surface-800">
      <div class="container-page py-10">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs font-medium bg-brand-100 dark:bg-brand-900 text-brand-700 dark:text-brand-300 px-2.5 py-1 rounded-full">
            {subjectName}
          </span>
          <span class="text-xs text-surface-400">{weight}% exam weight</span>
        </div>
        <h1 class="heading-1 text-surface-900 dark:text-surface-50 mb-4">{topicName}</h1>
        <p class="text-surface-600 dark:text-surface-400 max-w-2xl">
          Part of the {examName} study roadmap. {subjectName} topic {topic} of {subjectName}.
        </p>
        <!-- Generate roadmap CTA -->
        <div class="mt-6 flex gap-3 flex-wrap">
          <a href={`/roadmap?exam=${exam}`} class="btn-primary inline-flex items-center gap-2">
            → See in Roadmap
          </a>
          <a href={`/roadmap?exam=${exam}&duration=1mo`} class="btn-secondary inline-flex items-center gap-2">
            Build 1-Month Plan
          </a>
        </div>
      </div>
    </section>

    <!-- Note content -->
    <section class="container-page py-12">
      <div class="grid lg:grid-cols-3 gap-10">
        <!-- Main content -->
        <article class="lg:col-span-2">
          <div class="prose prose-surface dark:prose-invert max-w-none
              prose-headings:text-surface-900 dark:prose-headings:text-surface-50
              prose-p:text-surface-700 dark:prose-p:text-surface-300
              prose-li:text-surface-700 dark:prose-li:text-surface-300
              prose-strong:text-surface-900 dark:prose-strong:text-surface-100
              prose-code:text-brand-700 dark:prose-code:text-brand-300
              prose-pre:bg-surface-100 dark:prose-pre:bg-surface-900
              prose-table:text-sm
              prose-th:bg-surface-100 dark:prose-th:bg-surface-800
              prose-tr:border-surface-200 dark:prose-tr:border-surface-700">
            <Content />
          </div>

          <!-- Diagram prompt section -->
          {diagramPrompt && (
            <div class="mt-8 p-5 bg-brand-50 dark:bg-brand-950 border border-brand-200 dark:border-brand-800 rounded-xl">
              <h3 class="text-sm font-semibold text-brand-700 dark:text-brand-300 mb-2 flex items-center gap-2">
                📐 Diagram Reference
              </h3>
              <p class="text-sm text-surface-600 dark:text-surface-400 italic">
                {diagramPrompt}
              </p>
              <p class="text-xs text-surface-400 mt-2">
                Diagrams are generated per-topic using AI. Support for AI-generated educational diagrams coming soon.
              </p>
            </div>
          )}
        </article>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- Note metadata -->
          <div class="bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-700 rounded-xl p-5">
            <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 mb-4">Note Details</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-surface-500">Exam</dt>
                <dd class="font-medium text-surface-900 dark:text-surface-100">{examName}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-surface-500">Subject</dt>
                <dd class="font-medium text-surface-900 dark:text-surface-100">{subjectName}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-surface-500">Topic ID</dt>
                <dd class="font-mono text-xs text-surface-600 dark:text-surface-400">{topic}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-surface-500">Exam Weight</dt>
                <dd class="font-medium text-brand-600 dark:text-brand-400">{weight}%</dd>
              </div>
            </dl>
          </div>

          <!-- CTA -->
          <div class="bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl p-5 text-white">
            <h3 class="font-semibold mb-2">Ready to study?</h3>
            <p class="text-sm text-brand-100 mb-4">Build a personalised {examName} roadmap in seconds — free, no signup.</p>
            <a href={`/roadmap?exam=${exam}`} class="block text-center bg-white text-brand-700 font-medium rounded-lg py-2.5 px-4 hover:bg-brand-50 transition">
              Generate My Roadmap →
            </a>
          </div>

          <!-- Related notes -->
          {sameExamSubject.length > 0 && (
            <div class="border border-surface-200 dark:border-surface-700 rounded-xl p-5">
              <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 mb-3">More {subjectName} Notes</h3>
              <ul class="space-y-2">
                {sameExamSubject.map(n => (
                  <li>
                    <a
                      href={`/notes/${n.id}`}
                      class="text-sm text-surface-600 dark:text-surface-400 hover:text-brand-600 dark:hover:text-brand-400 flex items-center gap-1.5"
                    >
                      <span class="text-surface-400">→</span>
                      {n.data.topicName}
                    </a>
                  </li>
                ))}
              </ul>
              <a href={`/notes/${exam}/${subject}`} class="text-xs text-brand-600 dark:text-brand-400 hover:underline mt-3 block">
                View all {subjectName} →
              </a>
            </div>
          )}
        </aside>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
